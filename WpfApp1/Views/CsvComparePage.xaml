<Page x:Class="WpfApp1.Views.CsvComparePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F4F8"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      SizeChanged="Page_SizeChanged">
    <Page.Resources>

        <!-- 卡片 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="20" />
        </Style>

        <!-- 按钮基础模板 -->
        <ControlTemplate x:Key="BtnTpl" TargetType="Button">
            <Border x:Name="R" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="9" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="R" Property="Opacity" Value="0.88" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="R" Property="Opacity" Value="0.76" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="R" Property="Opacity" Value="0.42" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#4F6AF4" />
            <Setter Property="BorderBrush" Value="#4F6AF4" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template" Value="{StaticResource BtnTpl}" />
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#EEF2FF" />
            <Setter Property="BorderBrush" Value="#C7D2FE" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#3730A3" />
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#475569" />
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#059669" />
            <Setter Property="BorderBrush" Value="#059669" />
        </Style>

        <!-- 对比模式 RadioButton -->
        <Style x:Key="ModeRadio" TargetType="RadioButton">
            <Setter Property="Foreground" Value="#64748B" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="R" Background="Transparent" CornerRadius="7"
                                Padding="{TemplateBinding Padding}" BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="R" Property="Background" Value="#4F6AF4" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="R" Property="Background" Value="#E8EDFF" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True" />
                                    <Condition Property="IsMouseOver" Value="True" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="R" Property="Opacity" Value="0.9" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 主键列 CheckBox（竖向列表项样式） -->
        <Style x:Key="KeyColumnCheckBox" TargetType="CheckBox">
            <Setter Property="Margin" Value="0,0,0,2" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="Row" Background="Transparent" CornerRadius="7"
                                BorderThickness="1" BorderBrush="Transparent" Padding="10,7">
                            <DockPanel>
                                <Border x:Name="Box" DockPanel.Dock="Left"
                                        Width="15" Height="15" CornerRadius="3"
                                        Background="White" BorderBrush="#CBD5E1" BorderThickness="1.5"
                                        Margin="0,0,9,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="Chk" Text="✓" FontSize="9" FontWeight="Bold"
                                               Foreground="White" HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Visibility="Collapsed" />
                                </Border>
                                <ContentPresenter VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="Background" Value="#4F6AF4" />
                                <Setter TargetName="Box" Property="BorderBrush" Value="#4F6AF4" />
                                <Setter TargetName="Chk" Property="Visibility" Value="Visible" />
                                <Setter TargetName="Row" Property="Background" Value="#EEF2FF" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="#C7D2FE" />
                                <Setter Property="Foreground" Value="#3730A3" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Row" Property="Background" Value="#F8FAFC" />
                                <Setter TargetName="Row" Property="BorderBrush" Value="#E2E8F0" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 筛选 CheckBox（胶囊标签） -->
        <Style x:Key="FilterChip" TargetType="CheckBox">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Border x:Name="Pill" Background="#F8FAFC" BorderBrush="#E2E8F0"
                                    BorderThickness="1" CornerRadius="8" Padding="11,5">
                            <DockPanel>
                                <Ellipse x:Name="Dot" Width="7" Height="7" Fill="#CBD5E1"
                                         Margin="0,0,6,0" VerticalAlignment="Center" DockPanel.Dock="Left" />
                                <ContentPresenter VerticalAlignment="Center" />
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Pill" Property="Background" Value="#EEF2FF" />
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#A5B4FC" />
                                <Setter Property="Foreground" Value="#3730A3" />
                                <Setter TargetName="Dot" Property="Fill" Value="#6366F1" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Pill" Property="BorderBrush" Value="#A5B4FC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ 每页行数 ComboBox ═══ -->
        <Style x:Key="PageSizeCombo" TargetType="ComboBox">
            <!-- 下拉项隐式样式（必须放在 Setter 之前） -->
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="Foreground" Value="#374151" />
                    <Setter Property="Padding" Value="12,7" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd" Background="Transparent"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}"
                                        Margin="3,1">
                                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#EEF2FF" />
                                        <Setter Property="Foreground" Value="#3730A3" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#EEF2FF" />
                                        <Setter Property="Foreground" Value="#3730A3" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
            <Setter Property="Height" Value="30" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#CBD5E1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- 主体边框 -->
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid Margin="10,0,28,0">
                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center" />
                                </Grid>
                            </Border>
                            <!-- 右侧箭头区 -->
                            <Border x:Name="ArrowZone" Width="24" HorizontalAlignment="Right"
                                    CornerRadius="0,8,8,0" Background="Transparent">
                                <Path x:Name="Arrow" Data="M 0 0 L 4 5 L 8 0"
                                      Stroke="#94A3B8" StrokeThickness="1.5" StrokeLineJoin="Round"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <!-- 透明 ToggleButton（覆盖整个控件以响应点击，无任何视觉效果） -->
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Rectangle Fill="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- 下拉弹出 -->
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   Placement="Bottom"
                                   PopupAnimation="Fade"
                                   MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                        CornerRadius="10" Margin="0,4,0,0" Padding="4,4">
                                    <Border.Effect>
                                        <DropShadowEffect ShadowDepth="2" BlurRadius="12"
                                                          Color="#000000" Opacity="0.10"
                                                          Direction="270" />
                                    </Border.Effect>
                                    <ScrollViewer SnapsToDevicePixels="True" MaxHeight="200"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#A5B4FC" />
                                <Setter TargetName="Arrow" Property="Stroke" Value="#6366F1" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4F6AF4" />
                                <Setter TargetName="Arrow" Property="Data" Value="M 0 5 L 4 0 L 8 5" />
                                <Setter TargetName="Arrow" Property="Stroke" Value="#4F6AF4" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ DataGrid 样式 ═══ -->
        <Style x:Key="ResultDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#F1F5F9" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="CanUserReorderColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
            <Setter Property="RowHeaderWidth" Value="0" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="AlternatingRowBackground" Value="#FAFBFD" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="EnableColumnVirtualization" Value="False" />
            <Setter Property="EnableRowVirtualization" Value="False" />
        </Style>

        <!-- 列表头 -->
        <Style x:Key="ResultDataGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F4F7FB" />
            <Setter Property="Foreground" Value="#374151" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="10,10" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,1,1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 单元格 -->
        <Style x:Key="ResultDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 行 -->
        <Style x:Key="ResultDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="White" />
            <Setter Property="Foreground" Value="#1E293B" />
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <!-- ① 差异类型底色（DataTrigger，优先级低于后面的 Trigger） -->
                <DataTrigger Binding="{Binding DiffGroupType}" Value="RowRemoved">
                    <Setter Property="Background" Value="#FFF0F0" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DiffGroupType}" Value="RowAdded">
                    <Setter Property="Background" Value="#F0FDF4" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DiffGroupType}" Value="CellModified">
                    <Setter Property="Background" Value="#FFFBEB" />
                </DataTrigger>
                <DataTrigger Binding="{Binding DiffGroupType}" Value="DuplicateKey">
                    <Setter Property="Background" Value="#FEF3C7" />
                </DataTrigger>

                <!-- ② 悬停：淡灰，覆盖差异底色 -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F0F2F8" />
                </Trigger>

                <!-- ③ 选中：极浅底色 + 左侧 3px 紫线，文字保持原色 -->
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EDEFFE" />
                    <Setter Property="BorderBrush" Value="#6366F1" />
                    <Setter Property="BorderThickness" Value="3,0,0,0" />
                </Trigger>

                <!-- ④ 选中 + 悬停 -->
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True" />
                        <Condition Property="IsMouseOver" Value="True" />
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#E4E6FD" />
                    <Setter Property="BorderBrush" Value="#6366F1" />
                    <Setter Property="BorderThickness" Value="3,0,0,0" />
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <!-- 行号表头样式 -->
        <Style x:Key="SummaryRowHeader" TargetType="DataGridRowHeader">
            <Setter Property="Background" Value="#F4F7FB" />
            <Setter Property="Foreground" Value="#94A3B8" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Width" Value="36" />
            <Setter Property="BorderBrush" Value="#E2E8F0" />
            <Setter Property="BorderThickness" Value="0,0,1,0" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRowHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Width="{TemplateBinding Width}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WrapCellText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <!-- A 列（红色，始终保持） -->
        <Style x:Key="AValueText" TargetType="TextBlock" BasedOn="{StaticResource WrapCellText}">
            <Setter Property="Foreground" Value="#B91C1C" />
        </Style>

        <!-- B 列（绿色，始终保持） -->
        <Style x:Key="BValueText" TargetType="TextBlock" BasedOn="{StaticResource WrapCellText}">
            <Setter Property="Foreground" Value="#065F46" />
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="PageScrollViewer"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  PanningMode="VerticalOnly">
        <StackPanel Margin="18,14,18,24">

            <!-- ─── 页头 ─── -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="CSV 对比工具" FontSize="22" FontWeight="Bold" Foreground="#0F172A" />
                    <TextBlock Margin="0,4,0,0" FontSize="12" Foreground="#94A3B8"
                               Text="加载两个 CSV / TXT / TSV 文件，自动比对并高亮差异，支持行号或主键匹配。" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="交换 A↔B" Style="{StaticResource SecondaryButton}"
                            Margin="0,0,8,0" Click="BtnSwap_Click" />
                    <Button Content="清空" Style="{StaticResource GhostButton}" Click="BtnClear_Click" />
                </StackPanel>
            </Grid>

            <!-- ─── 文件卡片 ─── -->
            <Grid x:Name="FileCardsGrid" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 文件 A -->
                <Border x:Name="LeftFileCard" Grid.Column="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <!-- 标题行 -->
                        <DockPanel Grid.Row="0">
                            <Border Width="30" Height="30" CornerRadius="8" Background="#EEF2FF"
                                    DockPanel.Dock="Left" Margin="0,0,10,0" VerticalAlignment="Top">
                                <TextBlock Text="A" FontSize="14" FontWeight="Bold" Foreground="#4F6AF4"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="文件 A" FontSize="13" FontWeight="SemiBold" Foreground="#374151" />
                                <TextBlock x:Name="TxtLeftFileName" FontSize="13" Foreground="#1E293B"
                                           TextTrimming="CharacterEllipsis" Text="尚未加载" Margin="0,2,0,0" />
                            </StackPanel>
                        </DockPanel>
                        <!-- 元数据 -->
                        <TextBlock x:Name="TxtLeftMeta" Grid.Row="2" FontSize="11" Foreground="#94A3B8"
                                   TextWrapping="Wrap" Text="请选择左侧文件后开始自动比对。" />
                        <!-- 按钮 -->
                        <Button Grid.Row="4" Content="选择文件 A" Style="{StaticResource PrimaryButton}"
                                HorizontalAlignment="Left" Click="BtnLoadLeft_Click" />
                    </Grid>
                </Border>

                <!-- 文件 B -->
                <Border x:Name="RightFileCard" Grid.Column="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="6" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0">
                            <Border Width="30" Height="30" CornerRadius="8" Background="#F0FDF4"
                                    DockPanel.Dock="Left" Margin="0,0,10,0" VerticalAlignment="Top">
                                <TextBlock Text="B" FontSize="14" FontWeight="Bold" Foreground="#059669"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel>
                                <TextBlock Text="文件 B" FontSize="13" FontWeight="SemiBold" Foreground="#374151" />
                                <TextBlock x:Name="TxtRightFileName" FontSize="13" Foreground="#1E293B"
                                           TextTrimming="CharacterEllipsis" Text="尚未加载" Margin="0,2,0,0" />
                            </StackPanel>
                        </DockPanel>
                        <TextBlock x:Name="TxtRightMeta" Grid.Row="2" FontSize="11" Foreground="#94A3B8"
                                   TextWrapping="Wrap" Text="请选择右侧文件后开始自动比对。" />
                        <Button Grid.Row="4" Content="选择文件 B" Style="{StaticResource SuccessButton}"
                                HorizontalAlignment="Left" Click="BtnLoadRight_Click" />
                    </Grid>
                </Border>
            </Grid>

            <!-- ─── 对比设置 ─── -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                <StackPanel>
                    <!-- 标题 + 重新比对按钮 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="对比设置" FontSize="15" FontWeight="SemiBold" Foreground="#0F172A" />
                            <TextBlock x:Name="TxtModeHint" Margin="0,4,0,0" FontSize="12" Foreground="#94A3B8"
                                       Text="行号模式按第 N 行对第 N 行比较，主键模式按选中列匹配。" />
                        </StackPanel>
                        <Button x:Name="BtnCompare" Grid.Column="1" Content="开始比对"
                                Style="{StaticResource PrimaryButton}" VerticalAlignment="Center"
                                Click="BtnCompare_Click" />
                    </Grid>

                    <!-- 模式选择（Tab 胶囊） -->
                    <Border Margin="0,14,0,0" Background="#F1F5F9" CornerRadius="9"
                            Padding="3" HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="RbCompareByRow" Content="按行号对比"
                                         GroupName="CsvMode" Style="{StaticResource ModeRadio}"
                                         IsChecked="True" />
                            <RadioButton x:Name="RbCompareByKey" Content="按主键对比"
                                         GroupName="CsvMode" Style="{StaticResource ModeRadio}"
                                         Margin="2,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- 主键列面板（按主键时显示） -->
                    <Border x:Name="KeyColumnsContainer" Margin="0,12,0,0"
                            Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1"
                            CornerRadius="12" Padding="14" Visibility="Collapsed">
                        <StackPanel>
                            <!-- 主键区标题行 -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="选择主键列" FontSize="13" FontWeight="SemiBold"
                                               Foreground="#374151" />
                                    <TextBlock x:Name="TxtKeyColumnsHint" Margin="0,3,0,0"
                                               FontSize="11" Foreground="#94A3B8" TextWrapping="Wrap"
                                               Text="请勾选两侧共有字段作为主键，多选构成复合主键。" />
                                    <TextBlock x:Name="TxtKeyColumnsSummary" Margin="0,5,0,0"
                                               FontSize="12" FontWeight="SemiBold" Foreground="#4F6AF4"
                                               Text="当前未选择主键列" />
                                </StackPanel>
                                <Button x:Name="BtnToggleKeyColumns" Grid.Column="1"
                                        Style="{StaticResource GhostButton}" Content="收起"
                                        VerticalAlignment="Top" Padding="10,5"
                                        Click="BtnToggleKeyColumns_Click" />
                            </Grid>

                            <!-- 主键列竖向列表（可滚动） -->
                            <Border x:Name="KeyColumnsContentPanel" Margin="0,10,0,0"
                                    Background="White" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="9" Padding="8" MaxHeight="220">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <!-- 这里动态添加 CheckBox，默认用 KeyColumnCheckBox 样式 -->
                                    <StackPanel x:Name="KeyColumnsPanel">
                                        <StackPanel.Resources>
                                            <Style TargetType="CheckBox"
                                                   BasedOn="{StaticResource KeyColumnCheckBox}" />
                                        </StackPanel.Resources>
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ─── 对比结果 ─── -->
            <Border Style="{StaticResource Card}">
                <StackPanel>

                    <!-- 校验失败提示 -->
                    <Border x:Name="ValidationBanner" Background="#FEF2F2" BorderBrush="#FECACA"
                            BorderThickness="1" CornerRadius="10" Padding="14,10"
                            Margin="0,0,0,12" Visibility="Collapsed">
                        <DockPanel>
                            <TextBlock Text="⚠" Foreground="#DC2626" FontSize="15"
                                       Margin="0,0,8,0" VerticalAlignment="Top" DockPanel.Dock="Left" />
                            <TextBlock x:Name="TxtValidationMessage" Foreground="#991B1B"
                                       TextWrapping="Wrap" FontSize="12" />
                        </DockPanel>
                    </Border>

                    <!-- 结果标题行 -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="对比结果" FontSize="15" FontWeight="SemiBold"
                                       Foreground="#0F172A" />
                            <TextBlock x:Name="TxtSummary" Margin="0,4,0,0" FontSize="13"
                                       Foreground="#4F6AF4" FontWeight="SemiBold"
                                       Text="等待开始对比" />
                            <TextBlock x:Name="TxtScopeSummary" Margin="0,3,0,0"
                                       FontSize="11" Foreground="#94A3B8" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Top">
                            <CheckBox x:Name="ChkExportFilteredOnly" Content="仅导出筛选结果"
                                      VerticalAlignment="Center" FontSize="12" Margin="0,0,12,0" />
                            <Button x:Name="BtnCopyReport" Content="复制报告"
                                    Style="{StaticResource GhostButton}" Margin="0,0,8,0"
                                    Click="BtnCopyReport_Click" />
                            <Button x:Name="BtnExportResult" Content="导出 CSV"
                                    Style="{StaticResource SuccessButton}"
                                    Click="BtnExportResult_Click" />
                        </StackPanel>
                    </Grid>

                    <!-- 字段对比 Banner -->
                    <Border x:Name="HeaderChangesBanner" Background="#EFF6FF" BorderBrush="#BFDBFE"
                            BorderThickness="1" CornerRadius="10" Padding="14,10"
                            Margin="0,0,0,12" Visibility="Collapsed">
                        <DockPanel VerticalAlignment="Top">
                            <TextBlock Text="ℹ" Foreground="#2563EB" FontSize="13"
                                       Margin="0,1,8,0" DockPanel.Dock="Left" VerticalAlignment="Top" />
                            <TextBlock x:Name="TxtHeaderChangesSummary" Foreground="#1D4ED8"
                                       TextWrapping="Wrap" FontSize="12" />
                        </DockPanel>
                    </Border>

                    <!-- 筛选 + 分页 -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- 筛选胶囊 -->
                        <WrapPanel VerticalAlignment="Center">
                            <CheckBox x:Name="ChkShowColumnChanges" Content="字段差异"
                                      IsChecked="True" Style="{StaticResource FilterChip}" />
                            <CheckBox x:Name="ChkShowRowChanges" Content="新增/缺失行"
                                      IsChecked="True" Style="{StaticResource FilterChip}" />
                            <CheckBox x:Name="ChkShowCellChanges" Content="单元格差异"
                                      IsChecked="True" Style="{StaticResource FilterChip}" />
                        </WrapPanel>

                        <!-- 分页控件 -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="每页" FontSize="12" Foreground="#64748B"
                                       VerticalAlignment="Center" Margin="0,0,5,0" />
                            <ComboBox x:Name="CmbPageSize" Width="72"
                                      Style="{StaticResource PageSizeCombo}" />
                            <TextBlock Text="行" FontSize="12" Foreground="#64748B"
                                       VerticalAlignment="Center" Margin="4,0,14,0" />
                            <TextBlock x:Name="TxtPageInfo" FontSize="12" Foreground="#64748B"
                                       VerticalAlignment="Center" Margin="0,0,12,0"
                                       Text="第 0 / 0 页" />
                            <Button Content="«" Style="{StaticResource GhostButton}"
                                    Padding="8,4" Margin="0,0,4,0" Click="BtnFirstPage_Click" />
                            <Button Content="‹" Style="{StaticResource GhostButton}"
                                    Padding="8,4" Margin="0,0,4,0" Click="BtnPrevPage_Click" />
                            <Button Content="›" Style="{StaticResource GhostButton}"
                                    Padding="8,4" Margin="0,0,4,0" Click="BtnNextPage_Click" />
                            <Button Content="»" Style="{StaticResource GhostButton}"
                                    Padding="8,4" Click="BtnLastPage_Click" />
                        </StackPanel>
                    </Grid>

                    <!-- 空状态 -->
                    <TextBlock x:Name="TxtResultEmptyState" Padding="0,6"
                               Foreground="#94A3B8" FontSize="13"
                               Text="当前没有可显示的差异结果。" />

                    <!-- 汇总 DataGrid（行色彩区分差异类型） -->
                    <DataGrid x:Name="DgSummaryRows" Height="290"
                              RowHeaderWidth="36"
                              Style="{StaticResource ResultDataGrid}"
                              ColumnHeaderStyle="{StaticResource ResultDataGridHeader}"
                              CellStyle="{StaticResource ResultDataGridCell}"
                              RowStyle="{StaticResource ResultDataGridRow}"
                              RowHeaderStyle="{StaticResource SummaryRowHeader}"
                              Visibility="Collapsed"
                              SelectionChanged="DgSummaryRows_SelectionChanged"
                              LoadingRow="DgSummaryRows_LoadingRow"
                              PreviewMouseWheel="ResultGrid_PreviewMouseWheel">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="类型" Width="90"
                                                Binding="{Binding DiffTypeText}" />
                            <DataGridTextColumn Header="定位" Width="160"
                                                Binding="{Binding Locator}" />
                            <DataGridTemplateColumn Header="差异摘要" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding SummaryText}"
                                                   Style="{StaticResource WrapCellText}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="项数" Width="50"
                                                Binding="{Binding DiffCount}" />
                            <DataGridTemplateColumn Header="A 值（删除/修改前）" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding LeftPreview}"
                                                   Style="{StaticResource AValueText}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="B 值（新增/修改后）" Width="200">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding RightPreview}"
                                                   Style="{StaticResource BValueText}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- 差异明细面板 -->
                    <Border Margin="0,12,0,0" Background="#F8FAFC" BorderBrush="#E2E8F0"
                            BorderThickness="1" CornerRadius="12" Padding="14">
                        <StackPanel>
                            <TextBlock x:Name="TxtDetailTitle" FontSize="13" FontWeight="SemiBold"
                                       Foreground="#374151" TextWrapping="Wrap"
                                       Text="请选择上方一条结果以查看明细。" />

                            <!-- A/B 行预览 -->
                            <Grid Margin="0,10,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="White" BorderBrush="#FECACA"
                                        BorderThickness="1" CornerRadius="8" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="A（删除前）" FontSize="10" FontWeight="Bold"
                                                   Foreground="#DC2626" Margin="0,0,0,4" />
                                        <TextBlock x:Name="TxtDetailLeftPreview" FontSize="12"
                                                   Foreground="#374151" TextWrapping="Wrap" Text="—" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="White" BorderBrush="#BBF7D0"
                                        BorderThickness="1" CornerRadius="8" Padding="12,8">
                                    <StackPanel>
                                        <TextBlock Text="B（新增后）" FontSize="10" FontWeight="Bold"
                                                   Foreground="#059669" Margin="0,0,0,4" />
                                        <TextBlock x:Name="TxtDetailRightPreview" FontSize="12"
                                                   Foreground="#374151" TextWrapping="Wrap" Text="—" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <TextBlock x:Name="TxtDetailEmptyState" Foreground="#94A3B8" FontSize="12"
                                       Text="请选择上方一条汇总结果以查看具体明细。" />

                            <DataGrid x:Name="DgDetailRows" Height="200"
                                      Style="{StaticResource ResultDataGrid}"
                                      ColumnHeaderStyle="{StaticResource ResultDataGridHeader}"
                                      CellStyle="{StaticResource ResultDataGridCell}"
                                      RowStyle="{StaticResource ResultDataGridRow}"
                                      Visibility="Collapsed"
                                      PreviewMouseWheel="ResultGrid_PreviewMouseWheel">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="字段" Width="150"
                                                        Binding="{Binding ColumnName}" />
                                    <DataGridTemplateColumn Header="A 值" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding LeftValue}"
                                                           Style="{StaticResource AValueText}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="B 值" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding RightValue}"
                                                           Style="{StaticResource BValueText}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="说明" Width="170">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Message}"
                                                           Style="{StaticResource WrapCellText}" />
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
