<Page x:Class="WpfApp1.Views.CsvComparePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F6F8"
      SizeChanged="Page_SizeChanged">
    <Page.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinWidth" Value="88"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4E6EF2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>
        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#475569"/>
        </Style>
        <Style x:Key="FlatComboBox" TargetType="ComboBox">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="10,0,6,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"/>
                                    <Border Grid.Column="1" Background="#F8FAFC" CornerRadius="0,8,8,0">
                                        <TextBlock Text="▼"
                                                   FontSize="10"
                                                   Foreground="#64748B"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="White"
                                        BorderBrush="#CBD5E1"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ScrollViewer MaxHeight="220">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#4E6EF2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="FlatComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#DBEAFE"/>
                                <Setter Property="Foreground" Value="#1D4ED8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WrapCellText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style x:Key="ResultDataGridHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style x:Key="ResultDataGridCell" TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#0F172A"/>
                    <Setter Property="Background" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ResultDataGridRow" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#EEF2F7"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="ItemsControl.AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFBFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8EEFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ResultDataGrid" TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowBackground" Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#FAFBFF"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEF2F7"/>
            <Setter Property="VerticalGridLinesBrush" Value="#F8FAFC"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="ColumnHeaderStyle" Value="{StaticResource ResultDataGridHeader}"/>
            <Setter Property="CellStyle" Value="{StaticResource ResultDataGridCell}"/>
            <Setter Property="RowStyle" Value="{StaticResource ResultDataGridRow}"/>
            <Setter Property="AlternationCount" Value="2"/>
        </Style>
    </Page.Resources>
    <Grid>
    <ScrollViewer x:Name="PageScrollViewer"
                  Style="{StaticResource PageScrollViewerStyle}"
                  Margin="0">
    <StackPanel Margin="20,16,20,20" VerticalAlignment="Top" MaxWidth="1200">
        <DockPanel Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="CSV 对比工具" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
                <TextBlock Text="支持按行号或复合主键对比两个带表头的 CSV / TXT / TSV 文件。"
                           Margin="0,4,0,0" FontSize="13" Foreground="#64748B"/>
            </StackPanel>
            <WrapPanel DockPanel.Dock="Right">
                <Button Content="交换左右" Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="BtnSwap_Click"/>
                <Button Content="清空" Margin="0,0,8,8" Style="{StaticResource GhostButton}" Click="BtnClear_Click"/>
                <Button x:Name="BtnCompare" Content="开始对比" Margin="0,0,0,8" IsEnabled="False"
                        Style="{StaticResource PrimaryButton}" Click="BtnCompare_Click"/>
            </WrapPanel>
        </DockPanel>
        <Grid x:Name="FileCardsGrid" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="0"/>
                <RowDefinition Height="0"/>
            </Grid.RowDefinitions>
            <Border x:Name="LeftFileCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource CardBorder}" Padding="16,14">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="文件 A（原始）" FontSize="14" FontWeight="SemiBold" Foreground="#1D4ED8" DockPanel.Dock="Left"/>
                        <Button Content="导入 A" DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Click="BtnLoadLeft_Click"/>
                    </DockPanel>
                    <TextBlock x:Name="TxtLeftFileName" Text="未选择文件" FontSize="13" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtLeftMeta" Text="支持 .csv / .txt / .tsv" Margin="0,6,0,0" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
            <Border x:Name="RightFileCard" Grid.Row="0" Grid.Column="2" Style="{StaticResource CardBorder}" Padding="16,14">
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="文件 B（对比）" FontSize="14" FontWeight="SemiBold" Foreground="#059669" DockPanel.Dock="Left"/>
                        <Button Content="导入 B" DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Click="BtnLoadRight_Click"/>
                    </DockPanel>
                    <TextBlock x:Name="TxtRightFileName" Text="未选择文件" FontSize="13" FontWeight="SemiBold" Foreground="#111827" TextWrapping="Wrap"/>
                    <TextBlock x:Name="TxtRightMeta" Text="支持 .csv / .txt / .tsv" Margin="0,6,0,0" FontSize="12" Foreground="#64748B" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
        <StackPanel Margin="0,0,0,14">
            <Border Style="{StaticResource CardBorder}" Padding="16,14" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="对比配置" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                    <WrapPanel Margin="0,12,0,0">
                        <RadioButton x:Name="RbCompareByRow" Content="行号模式" IsChecked="True" Margin="0,0,18,8" Checked="CompareMode_Checked"/>
                        <RadioButton x:Name="RbCompareByKey" Content="主键模式" Margin="0,0,0,8" Checked="CompareMode_Checked"/>
                    </WrapPanel>
                    <TextBlock x:Name="TxtModeHint" Margin="0,6,0,0" FontSize="12" Foreground="#64748B" Text="行号模式会按第 N 行对第 N 行进行比较。"/>
                    <Border x:Name="KeyColumnsContainer" Margin="0,12,0,0" Padding="12,10" Background="#F8FAFC"
                            BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="主键列选择" FontSize="12.5" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock x:Name="TxtKeyColumnsHint" Margin="0,4,0,10" FontSize="12" Foreground="#64748B" Text="请选择一个或多个公共列作为复合主键。"/>
                            <WrapPanel x:Name="KeyColumnsPanel"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            <Border x:Name="ValidationBanner" Padding="14,12" Background="#FEF2F2" BorderBrush="#FCA5A5" BorderThickness="1"
                    CornerRadius="8" Visibility="Collapsed">
                <TextBlock x:Name="TxtValidationMessage" FontSize="12.5" Foreground="#B91C1C" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>
        <Border Style="{StaticResource CardBorder}" Padding="16,14" MinHeight="720" Margin="0,0,0,4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,12">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="对比结果" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                        <TextBlock x:Name="TxtSummary" Margin="0,4,0,0" FontSize="12" Foreground="#64748B" Text="请先导入两个文件并执行对比。"/>
                    </StackPanel>
                    <TextBlock x:Name="TxtScopeSummary" DockPanel.Dock="Right" FontSize="12" Foreground="#64748B"/>
                </DockPanel>
                <Border x:Name="HeaderChangesBanner" Grid.Row="1" Margin="0,0,0,12" Padding="12,10" Background="#FFF7ED"
                        BorderBrush="#FDBA74" BorderThickness="1" CornerRadius="8" Visibility="Collapsed">
                    <TextBlock x:Name="TxtHeaderChangesSummary" FontSize="12" Foreground="#9A3412" TextWrapping="Wrap"/>
                </Border>
                <WrapPanel Grid.Row="2" Margin="0,0,0,12">
                    <CheckBox x:Name="ChkShowColumnChanges" Content="列变更" Margin="0,0,10,8" IsChecked="True" Checked="FilterChanged" Unchecked="FilterChanged"/>
                    <CheckBox x:Name="ChkShowRowChanges" Content="行变更" Margin="0,0,10,8" IsChecked="True" Checked="FilterChanged" Unchecked="FilterChanged"/>
                    <CheckBox x:Name="ChkShowCellChanges" Content="单元格修改" Margin="0,0,14,8" IsChecked="True" Checked="FilterChanged" Unchecked="FilterChanged"/>
                    <TextBlock Text="每页" VerticalAlignment="Center" Margin="0,0,8,8" FontSize="12" Foreground="#64748B"/>
                    <ComboBox x:Name="CmbPageSize" Width="92" Margin="0,0,12,8" Style="{StaticResource FlatComboBox}" ItemContainerStyle="{StaticResource FlatComboBoxItem}" SelectionChanged="CmbPageSize_SelectionChanged"/>
                    <Button Content="首页" Margin="0,0,8,8" Style="{StaticResource GhostButton}" Click="BtnFirstPage_Click"/>
                    <Button Content="上一页" Margin="0,0,8,8" Style="{StaticResource GhostButton}" Click="BtnPrevPage_Click"/>
                    <TextBlock x:Name="TxtPageInfo" VerticalAlignment="Center" Margin="0,0,12,8" FontSize="12" Foreground="#64748B"/>
                    <Button Content="下一页" Margin="0,0,8,8" Style="{StaticResource GhostButton}" Click="BtnNextPage_Click"/>
                    <Button Content="末页" Margin="0,0,12,8" Style="{StaticResource GhostButton}" Click="BtnLastPage_Click"/>
                    <CheckBox x:Name="ChkExportFilteredOnly" Content="仅导出当前筛选结果" Margin="0,0,12,8" VerticalAlignment="Center"/>
                    <Button x:Name="BtnCopyReport" Content="复制报告" Margin="0,0,8,8" Style="{StaticResource SecondaryButton}" Click="BtnCopyReport_Click" IsEnabled="False"/>
                    <Button x:Name="BtnExportResult" Content="导出结果" Margin="0,0,0,8" Style="{StaticResource PrimaryButton}" Click="BtnExportResult_Click" IsEnabled="False"/>
                </WrapPanel>
                <Grid Grid.Row="3" Height="340" MinHeight="260">
                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Background="White">
                        <Grid>
                            <DataGrid x:Name="DgSummaryRows" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                      CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserResizeRows="False" CanUserSortColumns="False"
                                      Style="{StaticResource ResultDataGrid}" MinRowHeight="34"
                                      EnableRowVirtualization="True" EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                                      ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      SelectionChanged="DgSummaryRows_SelectionChanged"
                                      PreviewMouseWheel="ResultGrid_PreviewMouseWheel"
                                      Visibility="Collapsed">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="差异类型" Binding="{Binding DiffTypeText}" Width="110"/>
                                    <DataGridTextColumn Header="定位" Binding="{Binding Locator}" Width="170"/>
                                    <DataGridTemplateColumn Header="差异摘要" Width="1.4*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate><TextBlock Text="{Binding SummaryText}" Style="{StaticResource WrapCellText}"/></DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="差异数" Binding="{Binding DiffCount}" Width="74"/>
                                    <DataGridTemplateColumn Header="A 行预览" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate><TextBlock Text="{Binding LeftPreview}" Style="{StaticResource WrapCellText}"/></DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTemplateColumn Header="B 行预览" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate><TextBlock Text="{Binding RightPreview}" Style="{StaticResource WrapCellText}"/></DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock x:Name="TxtResultEmptyState" Margin="16" FontSize="12.5" Foreground="#94A3B8"
                                       TextWrapping="Wrap" Text="当前没有可显示的差异结果。"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </Grid>
                <Border Grid.Row="5" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Background="#FCFCFD" MinHeight="300">
                    <Grid Margin="14,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="差异明细" FontSize="13.5" FontWeight="SemiBold" Foreground="#111827"/>
                            <TextBlock x:Name="TxtDetailTitle" Margin="0,4,0,0" FontSize="12" Foreground="#64748B" Text="请选择上方一条汇总结果以查看具体明细。"/>
                        </StackPanel>
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10,8">
                                <StackPanel><TextBlock Text="文件 A 预览" FontSize="11.5" Foreground="#1D4ED8" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtDetailLeftPreview" Margin="0,6,0,0" FontSize="12" Foreground="#111827" TextWrapping="Wrap" Text="—"/></StackPanel>
                            </Border>
                            <Border Grid.Column="2" Background="White" BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="10,8">
                                <StackPanel><TextBlock Text="文件 B 预览" FontSize="11.5" Foreground="#059669" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="TxtDetailRightPreview" Margin="0,6,0,0" FontSize="12" Foreground="#111827" TextWrapping="Wrap" Text="—"/></StackPanel>
                            </Border>
                        </Grid>
                        <Grid Grid.Row="2" Height="220" MinHeight="180">
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Background="White">
                                <Grid>
                                    <DataGrid x:Name="DgDetailRows" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False"
                                              CanUserDeleteRows="False" CanUserReorderColumns="False" CanUserResizeRows="False" CanUserSortColumns="False"
                                              Style="{StaticResource ResultDataGrid}" MinRowHeight="34"
                                              EnableRowVirtualization="True" EnableColumnVirtualization="True"
                                              VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling"
                                              ScrollViewer.CanContentScroll="True" ScrollViewer.VerticalScrollBarVisibility="Auto"
                                              ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                              PreviewMouseWheel="ResultGrid_PreviewMouseWheel"
                                              Visibility="Collapsed">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="列名" Binding="{Binding ColumnName}" Width="160"/>
                                            <DataGridTemplateColumn Header="A 值" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate><TextBlock Text="{Binding LeftValue}" Style="{StaticResource WrapCellText}"/></DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="B 值" Width="*">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate><TextBlock Text="{Binding RightValue}" Style="{StaticResource WrapCellText}"/></DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                            <DataGridTemplateColumn Header="说明" Width="220">
                                                <DataGridTemplateColumn.CellTemplate>
                                                    <DataTemplate><TextBlock Text="{Binding Message}" Style="{StaticResource WrapCellText}"/></DataTemplate>
                                                </DataGridTemplateColumn.CellTemplate>
                                            </DataGridTemplateColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                    <TextBlock x:Name="TxtDetailEmptyState" Margin="16" FontSize="12.5" Foreground="#94A3B8"
                                               TextWrapping="Wrap" Text="请选择上方一条汇总结果以查看具体明细。"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </StackPanel>
    </ScrollViewer>
    </Grid>
</Page>
