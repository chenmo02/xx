<Page x:Class="WpfApp1.Views.CsvComparePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F6F8">

    <Page.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4E6EF2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>

        <Style x:Key="GhostButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#475569"/>
        </Style>

        <Style x:Key="DiffGridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20,16,20,20">
            <DockPanel Margin="0,0,0,14">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock Text="CSV 对比工具"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="#111827"/>
                    <TextBlock Text="支持按行号或按复合主键对比两个带表头的 CSV / TXT / TSV 文件。"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="#64748B"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button Content="交换左右"
                            Margin="0,0,8,0"
                            Style="{StaticResource SecondaryButton}"
                            Click="BtnSwap_Click"/>
                    <Button Content="清空"
                            Margin="0,0,8,0"
                            Style="{StaticResource GhostButton}"
                            Click="BtnClear_Click"/>
                    <Button x:Name="BtnCompare"
                            Content="开始对比"
                            IsEnabled="False"
                            Style="{StaticResource PrimaryButton}"
                            Click="BtnCompare_Click"/>
                </StackPanel>
            </DockPanel>

            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardBorder}"
                        Padding="16,14">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="文件 A（原始）"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#1D4ED8"
                                       DockPanel.Dock="Left"/>
                            <Button Content="导入 A"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnLoadLeft_Click"/>
                        </DockPanel>

                        <TextBlock x:Name="TxtLeftFileName"
                                   Text="未选择文件"
                                   FontSize="13"
                                   Foreground="#111827"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtLeftMeta"
                                   Text="支持 .csv / .txt / .tsv"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource CardBorder}"
                        Padding="16,14">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,10">
                            <TextBlock Text="文件 B（对比）"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#059669"
                                       DockPanel.Dock="Left"/>
                            <Button Content="导入 B"
                                    DockPanel.Dock="Right"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnLoadRight_Click"/>
                        </DockPanel>

                        <TextBlock x:Name="TxtRightFileName"
                                   Text="未选择文件"
                                   FontSize="13"
                                   Foreground="#111827"
                                   FontWeight="SemiBold"/>
                        <TextBlock x:Name="TxtRightMeta"
                                   Text="支持 .csv / .txt / .tsv"
                                   Margin="0,6,0,0"
                                   FontSize="12"
                                   Foreground="#64748B"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardBorder}"
                    Padding="16,14"
                    Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="对比配置"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="#111827"/>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,12,0,0">
                        <RadioButton x:Name="RbCompareByRow"
                                     Content="行号模式"
                                     IsChecked="True"
                                     Margin="0,0,18,0"
                                     Checked="CompareMode_Checked"/>
                        <RadioButton x:Name="RbCompareByKey"
                                     Content="主键模式"
                                     Checked="CompareMode_Checked"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtModeHint"
                               Margin="0,10,0,0"
                               FontSize="12"
                               Foreground="#64748B"
                               Text="行号模式会按第 N 行对第 N 行进行比较。"/>

                    <Border x:Name="KeyColumnsContainer"
                            Margin="0,12,0,0"
                            Padding="12,10"
                            Background="#F8FAFC"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="主键列选择"
                                       FontSize="12.5"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBlock x:Name="TxtKeyColumnsHint"
                                       Margin="0,4,0,10"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Text="请选择一个或多个公共列作为复合主键。"/>
                            <WrapPanel x:Name="KeyColumnsPanel"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <Border x:Name="ValidationBanner"
                    Margin="0,0,0,14"
                    Padding="14,12"
                    Background="#FEF2F2"
                    BorderBrush="#FCA5A5"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                <TextBlock x:Name="TxtValidationMessage"
                           FontSize="12.5"
                           Foreground="#B91C1C"
                           TextWrapping="Wrap"/>
            </Border>

            <Border Style="{StaticResource CardBorder}"
                    Padding="16,14">
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock Text="对比结果"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="#111827"/>
                            <TextBlock x:Name="TxtSummary"
                                       Margin="0,4,0,0"
                                       FontSize="12"
                                       Foreground="#64748B"
                                       Text="请先导入两个文件并执行对比。"/>
                        </StackPanel>

                        <StackPanel DockPanel.Dock="Right"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <CheckBox x:Name="ChkShowColumnChanges"
                                      Content="列变更"
                                      Margin="0,0,10,0"
                                      IsChecked="True"
                                      Checked="FilterChanged"
                                      Unchecked="FilterChanged"/>
                            <CheckBox x:Name="ChkShowRowChanges"
                                      Content="行变更"
                                      Margin="0,0,10,0"
                                      IsChecked="True"
                                      Checked="FilterChanged"
                                      Unchecked="FilterChanged"/>
                            <CheckBox x:Name="ChkShowCellChanges"
                                      Content="单元格修改"
                                      Margin="0,0,14,0"
                                      IsChecked="True"
                                      Checked="FilterChanged"
                                      Unchecked="FilterChanged"/>
                            <Button x:Name="BtnCopyReport"
                                    Content="复制报告"
                                    Margin="0,0,8,0"
                                    Style="{StaticResource SecondaryButton}"
                                    Click="BtnCopyReport_Click"
                                    IsEnabled="False"/>
                            <Button x:Name="BtnExportResult"
                                    Content="导出结果"
                                    Style="{StaticResource PrimaryButton}"
                                    Click="BtnExportResult_Click"
                                    IsEnabled="False"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBlock x:Name="TxtEmptyState"
                               Margin="0,8,0,12"
                               FontSize="12.5"
                               Foreground="#94A3B8"
                               TextWrapping="Wrap"
                               Text="当前没有可显示的差异结果。"/>

                    <DataGrid x:Name="DgDiffs"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              CanUserSortColumns="True"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="All"
                              BorderThickness="1"
                              BorderBrush="#E5E7EB"
                              HorizontalGridLinesBrush="#E5E7EB"
                              VerticalGridLinesBrush="#E5E7EB"
                              RowBackground="White"
                              AlternatingRowBackground="#FAFAFA"
                              ColumnHeaderStyle="{StaticResource DiffGridHeaderStyle}"
                              MinRowHeight="32"
                              Visibility="Collapsed">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="差异类型" Binding="{Binding DiffTypeText}" Width="130"/>
                            <DataGridTextColumn Header="定位" Binding="{Binding Locator}" Width="220"/>
                            <DataGridTextColumn Header="列名" Binding="{Binding ColumnName}" Width="160"/>
                            <DataGridTextColumn Header="A 值" Binding="{Binding LeftValue}" Width="*"/>
                            <DataGridTextColumn Header="B 值" Binding="{Binding RightValue}" Width="*"/>
                            <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="220"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
