<Page x:Class="WpfApp1.Views.JsonDiffPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F6F8">

    <Page.Resources>
        <Style x:Key="RBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="🔀 JSON 对比工具" FontSize="20" FontWeight="Bold" Foreground="#1A2332"/>
                <TextBlock Text="深度对比两个 JSON 的结构与值差异，精确到每个字段" FontSize="12" Foreground="#999" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="🔄 交换左右" Padding="12,6" FontSize="12" Margin="0,0,4,0"
                        Background="#6B7280" Foreground="White" Style="{StaticResource RBtn}" Click="BtnSwap_Click"/>
                <Button Content="🗑️ 清空" Padding="12,6" FontSize="12" Margin="0,0,4,0"
                        Background="#EF4444" Foreground="White" Style="{StaticResource RBtn}" Click="BtnClearAll_Click"/>
                <Button x:Name="BtnCompare" Content="⚡ 开始对比" Padding="16,6" FontSize="13" FontWeight="SemiBold"
                        Background="#4E6EF2" Foreground="White" Style="{StaticResource RBtn}" Click="BtnCompare_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- 主内容 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="180"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto" MinHeight="60"/>
            </Grid.RowDefinitions>

            <!-- 上半部分：左右 JSON 输入 -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 左侧 JSON A -->
                <Border Grid.Column="0" Background="White" CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" Opacity="0.05" BlurRadius="6"/>
                    </Border.Effect>
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="10,6" CornerRadius="8,8,0,0"
                                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <TextBlock Text="📄 JSON A（原始）" FontSize="13" FontWeight="Bold" Foreground="#1A56DB"
                                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="📂 导入" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                            Background="#6366F1" Foreground="White" Style="{StaticResource RBtn}" Click="BtnImportA_Click"/>
                                    <Button Content="美化" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                            Background="#3B82F6" Foreground="White" Style="{StaticResource RBtn}" Click="BtnBeautifyA_Click"/>
                                    <Button Content="🗑️" Padding="8,3" FontSize="11"
                                            Background="#F0F1F5" Foreground="#666" Style="{StaticResource RBtn}" Click="BtnClearA_Click"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <TextBox x:Name="TxtJsonA"
                                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontSize="13" FontFamily="Consolas, 'Courier New'"
                                 Background="#1E293B" Foreground="#A5F3FC" CaretBrush="#F59E0B"
                                 Padding="12,8" BorderThickness="0"/>
                    </DockPanel>
                </Border>

                <!-- 分隔条 -->
                <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                              Background="Transparent" Cursor="SizeWE"/>

                <!-- 右侧 JSON B -->
                <Border Grid.Column="2" Background="White" CornerRadius="8">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" Opacity="0.05" BlurRadius="6"/>
                    </Border.Effect>
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="10,6" CornerRadius="8,8,0,0"
                                BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                            <DockPanel>
                                <TextBlock Text="📄 JSON B（修改后）" FontSize="13" FontWeight="Bold" Foreground="#059669"
                                           VerticalAlignment="Center" DockPanel.Dock="Left"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="📂 导入" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                            Background="#6366F1" Foreground="White" Style="{StaticResource RBtn}" Click="BtnImportB_Click"/>
                                    <Button Content="美化" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                            Background="#3B82F6" Foreground="White" Style="{StaticResource RBtn}" Click="BtnBeautifyB_Click"/>
                                    <Button Content="🗑️" Padding="8,3" FontSize="11"
                                            Background="#F0F1F5" Foreground="#666" Style="{StaticResource RBtn}" Click="BtnClearB_Click"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                        <TextBox x:Name="TxtJsonB"
                                 AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                 FontSize="13" FontFamily="Consolas, 'Courier New'"
                                 Background="#1E293B" Foreground="#A5F3FC" CaretBrush="#F59E0B"
                                 Padding="12,8" BorderThickness="0"/>
                    </DockPanel>
                </Border>
            </Grid>

            <!-- 拖拽分隔 -->
            <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeNS"/>

            <!-- 下半部分：对比结果 -->
            <Border Grid.Row="2" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.05" BlurRadius="6"/>
                </Border.Effect>
                <DockPanel>
                    <!-- 结果工具栏 -->
                    <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="10,6" CornerRadius="8,8,0,0"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="📊 对比结果" FontSize="13" FontWeight="Bold" Foreground="#1A56DB"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="TxtDiffSummary" FontSize="12" Foreground="#6B7280"
                                       VerticalAlignment="Center" Margin="12,0,0,0" DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <!-- 筛选按钮 -->
                                <CheckBox x:Name="ChkShowAdded" Content="新增" IsChecked="True" FontSize="11"
                                          Foreground="#16A34A" VerticalAlignment="Center" Margin="0,0,8,0"
                                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                                <CheckBox x:Name="ChkShowRemoved" Content="删除" IsChecked="True" FontSize="11"
                                          Foreground="#DC2626" VerticalAlignment="Center" Margin="0,0,8,0"
                                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                                <CheckBox x:Name="ChkShowModified" Content="修改" IsChecked="True" FontSize="11"
                                          Foreground="#D97706" VerticalAlignment="Center" Margin="0,0,8,0"
                                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                                <CheckBox x:Name="ChkShowTypeChanged" Content="类型变化" IsChecked="True" FontSize="11"
                                          Foreground="#9333EA" VerticalAlignment="Center" Margin="0,0,12,0"
                                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                                <Button Content="📋 复制报告" Padding="10,4" FontSize="11" Margin="0,0,4,0"
                                        Background="#4E6EF2" Foreground="White" Style="{StaticResource RBtn}" Click="BtnCopyReport_Click"/>
                                <Button Content="💾 导出报告" Padding="10,4" FontSize="11"
                                        Background="#10B981" Foreground="White" Style="{StaticResource RBtn}" Click="BtnExportReport_Click"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- 差异列表 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Padding="0">
                        <StackPanel x:Name="DiffResultContainer" Margin="0"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
