<Page x:Class="WpfApp1.Views.CsvViewerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource PageBackgroundAltBrush}">

    <DockPanel Margin="24,18,24,22" LastChildFill="True">

        <!-- 页头 -->
        <Grid DockPanel.Dock="Top" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center"
                        Margin="0,0,18,0">
                <TextBlock Text="CSV 预览工具"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="#111827"/>
                <TextBlock Text="支持编码识别、分隔符识别和单元格定位查找。"
                           Margin="0,4,0,0"
                           FontSize="13"
                           Foreground="#64748B"/>
            </StackPanel>

            <Border Grid.Column="1"
                    Background="White"
                    CornerRadius="12"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    Padding="10,8"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center"
                                Margin="0,0,12,0">
                        <TextBlock Text="文件操作"
                                   FontSize="11"
                                   Foreground="#94A3B8"/>
                        <TextBlock Text="导入 CSV / TXT / TSV"
                                   FontSize="12"
                                   Foreground="#475569"
                                   FontWeight="SemiBold"/>
                    </StackPanel>

                    <Button x:Name="BtnOpen"
                            Content="打开文件"
                            MinWidth="108"
                            Background="#4E6EF2"
                            Foreground="White"
                            Style="{DynamicResource ButtonPrimary}"
                            Click="BtnOpen_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 文件信息 -->
        <Border DockPanel.Dock="Top"
                Style="{DynamicResource CardBorder}"
                Padding="16,12"
                Margin="0,0,0,12">
            <DockPanel>
                <TextBlock x:Name="TxtFileInfo"
                           Text="请选择一个 CSV 文件"
                           FontSize="13"
                           Foreground="#475569"
                           VerticalAlignment="Center"
                           DockPanel.Dock="Left"/>
                <TextBlock x:Name="TxtEncoding"
                           FontSize="12"
                           Foreground="#94A3B8"
                           VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- 查找栏 -->
        <Border DockPanel.Dock="Top"
                Style="{DynamicResource CardBorder}"
                Padding="14,12"
                Margin="0,0,0,12">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal"
                            DockPanel.Dock="Left"
                            VerticalAlignment="Center">
                    <TextBlock Text="查找"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#374151"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <TextBox x:Name="TxtSearch"
                             Width="360"
                             Style="{DynamicResource TextBoxStandard}"
                             KeyDown="TxtSearch_KeyDown"/>
                    <Button Content="查找"
                            Margin="10,0,0,0"
                            Background="#4E6EF2"
                            Foreground="White"
                            Style="{DynamicResource ButtonPrimary}"
                            Click="BtnSearch_Click"/>
                    <Button Content="下一个"
                            Margin="8,0,0,0"
                            Background="#64748B"
                            Foreground="White"
                            Style="{DynamicResource ButtonSecondary}"
                            Click="BtnNextMatch_Click"/>
                    <Button Content="清除"
                            Margin="8,0,0,0"
                            Background="#E5E7EB"
                            Foreground="#475569"
                            Style="{DynamicResource ButtonGhost}"
                            Click="BtnClearSearch_Click"/>
                </StackPanel>

                <TextBlock x:Name="TxtMatchInfo"
                           FontSize="12"
                           Foreground="#64748B"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- 数据区（填满剩余高度） -->
        <Border Style="{DynamicResource CardBorder}"
                Padding="16,14">
            <DockPanel LastChildFill="True">

                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="数据预览"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#1F2937"
                               DockPanel.Dock="Left"/>
                    <TextBlock Text="查找结果只定位当前单元格，不整行高亮"
                               FontSize="12"
                               Foreground="#94A3B8"
                               HorizontalAlignment="Right"/>
                </DockPanel>

                <DockPanel DockPanel.Dock="Bottom" Margin="0,10,0,0">
                    <TextBlock x:Name="TxtStatus"
                               Text="就绪"
                               FontSize="11.5"
                               Foreground="#64748B"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Left"/>
                    <TextBlock x:Name="TxtRowCol"
                               Text="未选择单元格"
                               FontSize="11.5"
                               Foreground="#64748B"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <Border BorderBrush="#D9D9D9"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="1"
                        Background="White">
                    <DataGrid x:Name="DgCsv"
                              AutoGenerateColumns="True"
                              IsReadOnly="True"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              CanUserReorderColumns="False"
                              CanUserResizeRows="False"
                              CanUserSortColumns="False"
                              MinColumnWidth="90"
                              Background="White"
                              BorderThickness="0"
                              GridLinesVisibility="All"
                              HorizontalGridLinesBrush="#E5E7EB"
                              VerticalGridLinesBrush="#E5E7EB"
                              FontSize="12"
                              HeadersVisibility="All"
                              RowHeaderWidth="50"
                              SelectionUnit="Cell"
                              SelectionMode="Single"
                              VerticalScrollBarVisibility="Visible"
                              HorizontalScrollBarVisibility="Auto"
                              EnableRowVirtualization="True"
                              EnableColumnVirtualization="True"
                              ColumnHeaderHeight="32"
                              RowBackground="White"
                              LoadingRow="DgCsv_LoadingRow"
                              SelectedCellsChanged="DgCsv_SelectedCellsChanged"
                              ColumnHeaderStyle="{DynamicResource DataGridHeaderStyle}"
                              RowHeaderStyle="{DynamicResource DataGridRowHeaderStyle}"
                              CellStyle="{DynamicResource DataGridCellStyle}"
                              RowStyle="{DynamicResource DataGridRowStyle}"/>
                </Border>

            </DockPanel>
        </Border>

    </DockPanel>
</Page>
