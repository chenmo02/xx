<Page x:Class="WpfApp1.Views.InvoicePrintPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource PageBackgroundBrush}" AllowDrop="True" Drop="Page_Drop" DragOver="Page_DragOver">

    <Page.Resources>
        <!-- 页面特有：刷新按钮（带边框的浅蓝风格） -->
        <Style x:Key="RefreshBtn" TargetType="Button">
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#3F5AE0"/>
            <Setter Property="Background" Value="#F8FAFF"/>
            <Setter Property="BorderBrush" Value="#C9D4FF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EDF2FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#AFC0FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E2EAFF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 页面特有：标签文字 -->
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- 页面特有：次级标签 -->
        <Style x:Key="SubLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#999"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 左侧：文件列表 ═══ -->
        <Border Grid.Column="0" Style="{DynamicResource CardBorder}" Padding="16,14" Margin="0,0,10,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="🖨️ 发票打印工具" FontSize="16" FontWeight="Bold" Foreground="#222" Margin="0,0,0,4"/>
                <TextBlock DockPanel.Dock="Top" Text="导入 PDF/OFD/图片，排版打印" FontSize="11.5" Foreground="#999" Margin="0,0,0,12"/>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Button Content="📂 导入文件" Style="{DynamicResource ButtonPrimary}" Margin="0,0,0,6" Click="BtnImportFiles_Click"/>
                    <Button Content="📁 导入文件夹" Style="{DynamicResource ButtonGhost}" Background="#F0F1F5" Foreground="#555" Padding="14,8" FontSize="12.5" Margin="0,0,0,4" Click="BtnImportFolder_Click"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" x:Name="TxtFileCount" Text="已导入 0 个文件" FontSize="11.5" Foreground="#999" Margin="0,0,0,6"/>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                    <Button Content="🗑️ 清空列表" Style="{DynamicResource ButtonGhost}" Background="#F0F1F5" Foreground="#555" Padding="14,8" FontSize="12.5" Margin="0,0,0,4" Click="BtnClearList_Click"/>
                    <Button Content="✅ 全选" Style="{DynamicResource ButtonGhost}" Background="#F0F1F5" Foreground="#555" Padding="14,8" FontSize="12.5" Margin="0,0,0,4" Click="BtnSelectAll_Click"/>
                </StackPanel>
                <ListBox x:Name="FileListBox" BorderThickness="0" Background="Transparent"
                         SelectionChanged="FileListBox_SelectionChanged" SelectionMode="Extended"
                         MouseDoubleClick="FileListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2,4">
                                <TextBlock Text="{Binding FileType}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="White" Background="#4E6EF2" Padding="4,2"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="#333"
                                               TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                    <TextBlock Text="{Binding FileSizeText}" FontSize="10.5" Foreground="#999"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══ 中间：预览区 ═══ -->
        <Border Grid.Column="1" Style="{DynamicResource CardBorder}" Padding="16,14" Margin="0,0,10,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="📄 打印预览" FontSize="14" FontWeight="SemiBold" Foreground="#222"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="↻ 旋转90°" Style="{DynamicResource ButtonSmall}" Background="#EDF0FF" Foreground="#4E6EF2" Padding="10,6" FontSize="12" Margin="0,0,6,0" Click="BtnRotate_Click"/>
                    <Button Content="🔍+" Style="{DynamicResource ButtonSmall}" Background="#EDF0FF" Foreground="#4E6EF2" Padding="10,6" FontSize="12" Margin="0,0,4,0" Click="BtnZoomIn_Click"/>
                    <Button Content="🔍-" Style="{DynamicResource ButtonSmall}" Background="#EDF0FF" Foreground="#4E6EF2" Padding="10,6" FontSize="12" Margin="0,0,4,0" Click="BtnZoomOut_Click"/>
                    <Button Content="1:1" Style="{DynamicResource ButtonSmall}" Background="#EDF0FF" Foreground="#4E6EF2" Padding="10,6" FontSize="12" Margin="0,0,6,0" Click="BtnZoomReset_Click"/>
                    <TextBlock x:Name="TxtZoomLevel" Text="100%" FontSize="12" Foreground="#999" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Ctrl+滚轮缩放" FontSize="10.5" Foreground="#BBB" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Top" x:Name="PanelPageNav" Orientation="Horizontal" Margin="0,0,0,8" Visibility="Collapsed">
                    <Button Content="◀ 上一页" Style="{DynamicResource ButtonSmall}" Background="#EDF0FF" Foreground="#4E6EF2" Padding="10,6" FontSize="12" Margin="0,0,6,0" Click="BtnPrevPage_Click"/>
                    <TextBlock x:Name="TxtPageInfo" Text="第 1 / 1 页" FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button Content="下一页 ▶" Style="{DynamicResource ButtonSmall}" Background="#EDF0FF" Foreground="#4E6EF2" Padding="10,6" FontSize="12" Click="BtnNextPage_Click"/>
                </StackPanel>
                <Grid>
                    <Border x:Name="DropHintPanel" Background="#FAFBFC" CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="2" Padding="40">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📥" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="拖拽发票文件到此处" FontSize="16" Foreground="#999" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="支持 PDF、OFD、JPG、PNG 格式" FontSize="12" Foreground="#BBB" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer x:Name="PreviewScroller" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto" Visibility="Collapsed" Background="#E8E8E8"
                                  PreviewMouseWheel="PreviewScroller_PreviewMouseWheel">
                        <Border x:Name="PreviewContainer" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20" Background="White">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
                            </Border.Effect>
                            <Grid x:Name="LayoutPreviewGrid"/>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ═══ 右侧：打印设置面板 ═══ -->
        <Border Grid.Column="2" Style="{DynamicResource CardBorder}" Padding="16,14">
            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="打印设置" FontSize="16" FontWeight="Bold" Foreground="#222" Margin="0,0,0,16"/>

                    <!-- 排版模板 -->
                    <TextBlock Text="排版模板" Style="{StaticResource LabelText}"/>
                    <ComboBox x:Name="CmbTemplate" Style="{DynamicResource ComboBoxStandard}" Margin="0,0,0,14"
                              SelectionChanged="CmbTemplate_SelectionChanged"/>

                    <TextBlock Text="打印机" Style="{StaticResource LabelText}"/>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox x:Name="CmbPrinter"
                                  Style="{DynamicResource ComboBoxStandard}"
                                  Grid.Column="0"
                                  DisplayMemberPath="Name"
                                  VerticalContentAlignment="Center"
                                  MinHeight="34"/>
                        <Button Grid.Column="2"
                                Content="↻ 刷新"
                                Style="{StaticResource RefreshBtn}"
                                MinWidth="84"
                                Click="BtnRefreshPrinters_Click"/>
                    </Grid>

                    <!-- 打印份数 + 纸张大小 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="打印份数" Style="{StaticResource LabelText}"/>
                            <TextBox x:Name="TxtCopies" Text="1" Style="{DynamicResource TextBoxStandard}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="纸张大小" Style="{StaticResource LabelText}"/>
                            <ComboBox x:Name="CmbPaperMode" Style="{DynamicResource ComboBoxStandard}"
                                      SelectionChanged="CmbPaperMode_Changed">
                                <ComboBoxItem Style="{DynamicResource ComboBoxItemStandard}" Content="A4" Tag="A4" IsSelected="True"/>
                                <ComboBoxItem Style="{DynamicResource ComboBoxItemStandard}" Content="发票专用纸" Tag="Invoice"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#EBEBEB" Margin="0,0,0,14"/>

                    <!-- 打印排版标题 -->
                    <TextBlock Text="打印排版" FontSize="16" FontWeight="Bold" Foreground="#222" Margin="0,0,0,14"/>

                    <!-- 纸张方向 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="纸张方向" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <RadioButton x:Name="RbPortrait" Content="纵向" GroupName="Orientation" IsChecked="True"
                                     FontSize="13" VerticalAlignment="Center" Margin="0,0,20,0"
                                     Checked="Orientation_Changed"/>
                        <RadioButton x:Name="RbLandscape" Content="横向" GroupName="Orientation"
                                     FontSize="13" VerticalAlignment="Center"
                                     Checked="Orientation_Changed"/>
                    </StackPanel>

                    <!-- 排版方式（可视化卡片） -->
                    <TextBlock Text="排版方式" Style="{StaticResource LabelText}"/>
                    <StackPanel x:Name="PanelLayoutCount" Orientation="Horizontal" Margin="0,0,0,14">
                        <!-- 1张/页 -->
                        <Border x:Name="LayoutCard1" Background="#F7F8FA" BorderBrush="#D1D5DB" BorderThickness="1.5"
                                CornerRadius="6" Width="68" Height="68" Margin="0,0,8,0" Cursor="Hand"
                                MouseLeftButtonUp="LayoutCard1_Click">
                            <Grid Margin="10">
                                <Border Background="#E0E7FF" CornerRadius="2"/>
                                <TextBlock Text="发票" FontSize="10" Foreground="#4E6EF2"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <!-- 2张/页 -->
                        <Border x:Name="LayoutCard2" Background="#F7F8FA" BorderBrush="#D1D5DB" BorderThickness="1.5"
                                CornerRadius="6" Width="68" Height="68" Margin="0,0,8,0" Cursor="Hand"
                                MouseLeftButtonUp="LayoutCard2_Click">
                            <Grid Margin="8,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="3"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="8" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="2" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="8" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <!-- 4张/页 -->
                        <Border x:Name="LayoutCard4" Background="#F7F8FA" BorderBrush="#D1D5DB" BorderThickness="1.5"
                                CornerRadius="6" Width="68" Height="68" Cursor="Hand"
                                MouseLeftButtonUp="LayoutCard4_Click">
                            <Grid Margin="6,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="3"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="7" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="2" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="7" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="0" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="7" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="2" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="7" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 添加裁剪线 -->
                    <CheckBox x:Name="ChkCutLine" Content="✂ 添加裁剪线" FontSize="13" Margin="0,0,0,14"
                              Checked="CutLine_Changed" Unchecked="CutLine_Changed"/>

                    <Border Height="1" Background="#EBEBEB" Margin="0,0,0,14"/>

                    <!-- 边距设置 -->
                    <TextBlock Text="边距设置 (mm)" Style="{StaticResource LabelText}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="上" Style="{StaticResource SubLabel}"/>
                            <TextBox x:Name="TxtMarginTop" Text="0" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="下" Style="{StaticResource SubLabel}"/>
                            <TextBox x:Name="TxtMarginBottom" Text="0" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="左" Style="{StaticResource SubLabel}"/>
                            <TextBox x:Name="TxtMarginLeft" Text="0" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="右" Style="{StaticResource SubLabel}"/>
                            <TextBox x:Name="TxtMarginRight" Text="0" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                        </StackPanel>
                    </Grid>

                    <!-- 套打偏移 -->
                    <StackPanel x:Name="PanelOffset" Margin="0,0,0,12" Visibility="Collapsed">
                        <TextBlock Text="套打偏移 (mm)" Style="{StaticResource LabelText}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="X" Style="{StaticResource SubLabel}"/>
                                <TextBox x:Name="TxtOffsetX" Text="0" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Y" Style="{StaticResource SubLabel}"/>
                                <TextBox x:Name="TxtOffsetY" Text="0" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- 打印质量 -->
                    <TextBlock Text="打印质量" Style="{StaticResource LabelText}"/>
                    <ComboBox x:Name="CmbQuality" Style="{DynamicResource ComboBoxStandard}" Margin="0,0,0,16" SelectedIndex="1">
                        <ComboBoxItem Style="{DynamicResource ComboBoxItemStandard}" Content="草稿 (150 DPI)"/>
                        <ComboBoxItem Style="{DynamicResource ComboBoxItemStandard}" Content="标准 (300 DPI)"/>
                        <ComboBoxItem Style="{DynamicResource ComboBoxItemStandard}" Content="高画质 (600 DPI)"/>
                    </ComboBox>

                    <Border Height="1" Background="#EBEBEB" Margin="0,0,0,14"/>

                    <!-- 操作按钮 -->
                    <Button Content="🖨️ 开始打印" Style="{DynamicResource ButtonPrimary}" FontSize="14"
                            FontWeight="SemiBold" Padding="16,11" Margin="0,0,0,6" Click="BtnPrint_Click2"/>
                    <Button Content="💾 保存为模板" Style="{DynamicResource ButtonGhost}" Background="#F0F1F5" Foreground="#555" Padding="14,8" FontSize="12.5" Margin="0,0,0,4" Click="BtnSaveTemplate_Click"/>
                    <Button Content="🗑️ 删除模板" Style="{DynamicResource ButtonGhost}" Background="#F0F1F5" Foreground="#555" Padding="14,8" FontSize="12.5" Margin="0,0,0,4" Click="BtnDeleteTemplate_Click"/>

                    <!-- 状态栏 -->
                    <Button Content="打印机预览" Style="{DynamicResource ButtonGhost}" Background="#F0F1F5" Foreground="#555" Padding="14,8" FontSize="12.5" Margin="0,0,0,4" Click="BtnPrinterPreview_Click"/>
                    <Border Background="#F0F4FF" CornerRadius="6" Padding="10,8" Margin="0,14,0,0">
                        <TextBlock x:Name="TxtStatus" Text="就绪" FontSize="12" Foreground="#4E6EF2" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
