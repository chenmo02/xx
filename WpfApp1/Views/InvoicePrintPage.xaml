<Page x:Class="WpfApp1.Views.InvoicePrintPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F6F8" AllowDrop="True" Drop="Page_Drop" DragOver="Page_DragOver">

    <Page.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,14"/>
            <Setter Property="BorderBrush" Value="#E5E5E5"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4E6EF2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#3B5BDB"/></Trigger>
                            <Trigger Property="IsEnabled" Value="False"><Setter TargetName="bd" Property="Background" Value="#B0BEC5"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecBtn" TargetType="Button">
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Background" Value="#F0F1F5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#E2E4EA"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ToolBtn" TargetType="Button">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#4E6EF2"/>
            <Setter Property="Background" Value="#EDF0FF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter TargetName="bd" Property="Background" Value="#D6DEFF"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="SubLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="#999"/>
        </Style>

        <!-- ═══ 美化 ComboBox 下拉框 ═══ -->
        <!-- 下拉按钮（右侧箭头） -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="8"
                        Background="{TemplateBinding Background}"
                        BorderBrush="#D1D5DB" BorderThickness="1"/>
                <Border Grid.Column="0" CornerRadius="8,0,0,8" Background="Transparent"/>
                <!-- 箭头 -->
                <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 5 5 L 10 0" Stroke="#888" StrokeThickness="1.5" Fill="Transparent"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#4E6EF2"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="#4E6EF2"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#4E6EF2"/>
                    <Setter TargetName="Border" Property="Background" Value="#F8F9FF"/>
                    <Setter TargetName="Arrow" Property="Data" Value="M 0 5 L 5 0 L 10 5"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="#4E6EF2"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <!-- ComboBox 主样式 -->
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#F7F8FA"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource ComboBoxToggleButton}"
                                          Background="{TemplateBinding Background}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="12,0,36,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="White" CornerRadius="8"
                                            BorderBrush="#E0E0E0" BorderThickness="1"
                                            Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.12" Color="#000"/>
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="0,6,0,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBoxItem 选项样式 -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}"
                                Margin="4,1" CornerRadius="6">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EDF0FF"/>
                                <Setter Property="Foreground" Value="#4E6EF2"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0E7FF"/>
                                <Setter Property="Foreground" Value="#3B5BDB"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ 左侧：文件列表 ═══ -->
        <Border Grid.Column="0" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="🖨️ 发票打印工具" FontSize="16" FontWeight="Bold" Foreground="#222" Margin="0,0,0,4"/>
                <TextBlock DockPanel.Dock="Top" Text="导入 PDF/OFD/图片，排版打印" FontSize="11.5" Foreground="#999" Margin="0,0,0,12"/>
                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Button Content="📂 导入文件" Style="{StaticResource PrimaryBtn}" Click="BtnImportFiles_Click"/>
                    <Button Content="📁 导入文件夹" Style="{StaticResource SecBtn}" Click="BtnImportFolder_Click"/>
                </StackPanel>
                <TextBlock DockPanel.Dock="Top" x:Name="TxtFileCount" Text="已导入 0 个文件" FontSize="11.5" Foreground="#999" Margin="0,0,0,6"/>
                <StackPanel DockPanel.Dock="Bottom" Margin="0,6,0,0">
                    <Button Content="🗑️ 清空列表" Style="{StaticResource SecBtn}" Click="BtnClearList_Click"/>
                    <Button Content="✅ 全选" Style="{StaticResource SecBtn}" Click="BtnSelectAll_Click"/>
                </StackPanel>
                <ListBox x:Name="FileListBox" BorderThickness="0" Background="Transparent"
                         SelectionChanged="FileListBox_SelectionChanged" SelectionMode="Extended"
                         MouseDoubleClick="FileListBox_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="2,4">
                                <TextBlock Text="{Binding FileType}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="White" Background="#4E6EF2" Padding="4,2"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <StackPanel>
                                    <TextBlock Text="{Binding FileName}" FontSize="12" Foreground="#333"
                                               TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                    <TextBlock Text="{Binding FileSizeText}" FontSize="10.5" Foreground="#999"/>
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══ 中间：预览区 ═══ -->
        <Border Grid.Column="1" Style="{StaticResource CardBorder}" Margin="0,0,10,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="📄 打印预览" FontSize="14" FontWeight="SemiBold" Foreground="#222"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="↻ 旋转90°" Style="{StaticResource ToolBtn}" Margin="0,0,6,0" Click="BtnRotate_Click"/>
                    <Button Content="🔍+" Style="{StaticResource ToolBtn}" Margin="0,0,4,0" Click="BtnZoomIn_Click"/>
                    <Button Content="🔍-" Style="{StaticResource ToolBtn}" Margin="0,0,4,0" Click="BtnZoomOut_Click"/>
                    <Button Content="1:1" Style="{StaticResource ToolBtn}" Margin="0,0,6,0" Click="BtnZoomReset_Click"/>
                    <TextBlock x:Name="TxtZoomLevel" Text="100%" FontSize="12" Foreground="#999" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Ctrl+滚轮缩放" FontSize="10.5" Foreground="#BBB" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Top" x:Name="PanelPageNav" Orientation="Horizontal" Margin="0,0,0,8" Visibility="Collapsed">
                    <Button Content="◀ 上一页" Style="{StaticResource ToolBtn}" Margin="0,0,6,0" Click="BtnPrevPage_Click"/>
                    <TextBlock x:Name="TxtPageInfo" Text="第 1 / 1 页" FontSize="12" Foreground="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button Content="下一页 ▶" Style="{StaticResource ToolBtn}" Click="BtnNextPage_Click"/>
                </StackPanel>
                <Grid>
                    <Border x:Name="DropHintPanel" Background="#FAFBFC" CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="2" Padding="40">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="📥" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="拖拽发票文件到此处" FontSize="16" Foreground="#999" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="支持 PDF、OFD、JPG、PNG 格式" FontSize="12" Foreground="#BBB" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer x:Name="PreviewScroller" HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto" Visibility="Collapsed" Background="#E8E8E8"
                                  PreviewMouseWheel="PreviewScroller_PreviewMouseWheel">
                        <Border x:Name="PreviewContainer" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20" Background="White">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.15"/>
                            </Border.Effect>
                            <Grid x:Name="LayoutPreviewGrid"/>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ═══ 右侧：打印设置面板 ═══ -->
        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
            <ScrollViewer VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock Text="打印设置" FontSize="16" FontWeight="Bold" Foreground="#222" Margin="0,0,0,16"/>

                    <!-- 排版模板 -->
                    <TextBlock Text="排版模板" Style="{StaticResource LabelText}"/>
                    <ComboBox x:Name="CmbTemplate" Margin="0,0,0,14"
                              SelectionChanged="CmbTemplate_SelectionChanged"/>

                    <!-- 打印份数 + 纸张大小 -->
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="打印份数" Style="{StaticResource LabelText}"/>
                            <TextBox x:Name="TxtCopies" Text="1" Padding="8,6" FontSize="12.5" Background="#F7F8FA" BorderBrush="#D1D5DB"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="纸张大小" Style="{StaticResource LabelText}"/>
                            <ComboBox x:Name="CmbPaperMode"
                                      SelectionChanged="CmbPaperMode_Changed">
                                <ComboBoxItem Content="A4" Tag="A4" IsSelected="True"/>
                                <ComboBoxItem Content="发票专用纸" Tag="Invoice"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>

                    <Border Height="1" Background="#EBEBEB" Margin="0,0,0,14"/>

                    <!-- 打印排版标题 -->
                    <TextBlock Text="打印排版" FontSize="16" FontWeight="Bold" Foreground="#222" Margin="0,0,0,14"/>

                    <!-- 纸张方向 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <TextBlock Text="纸张方向" Style="{StaticResource LabelText}" VerticalAlignment="Center" Margin="0,0,16,0"/>
                        <RadioButton x:Name="RbPortrait" Content="纵向" GroupName="Orientation" IsChecked="True"
                                     FontSize="13" VerticalAlignment="Center" Margin="0,0,20,0"
                                     Checked="Orientation_Changed"/>
                        <RadioButton x:Name="RbLandscape" Content="横向" GroupName="Orientation"
                                     FontSize="13" VerticalAlignment="Center"
                                     Checked="Orientation_Changed"/>
                    </StackPanel>

                    <!-- 排版方式（可视化卡片） -->
                    <TextBlock Text="排版方式" Style="{StaticResource LabelText}"/>
                    <StackPanel x:Name="PanelLayoutCount" Orientation="Horizontal" Margin="0,0,0,14">
                        <!-- 1张/页 -->
                        <Border x:Name="LayoutCard1" Background="#F7F8FA" BorderBrush="#D1D5DB" BorderThickness="1.5"
                                CornerRadius="6" Width="68" Height="68" Margin="0,0,8,0" Cursor="Hand"
                                MouseLeftButtonUp="LayoutCard1_Click">
                            <Grid Margin="10">
                                <Border Background="#E0E7FF" CornerRadius="2"/>
                                <TextBlock Text="发票" FontSize="10" Foreground="#4E6EF2"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <!-- 2张/页 -->
                        <Border x:Name="LayoutCard2" Background="#F7F8FA" BorderBrush="#D1D5DB" BorderThickness="1.5"
                                CornerRadius="6" Width="68" Height="68" Margin="0,0,8,0" Cursor="Hand"
                                MouseLeftButtonUp="LayoutCard2_Click">
                            <Grid Margin="8,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="3"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="8" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="2" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="8" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <!-- 4张/页 -->
                        <Border x:Name="LayoutCard4" Background="#F7F8FA" BorderBrush="#D1D5DB" BorderThickness="1.5"
                                CornerRadius="6" Width="68" Height="68" Cursor="Hand"
                                MouseLeftButtonUp="LayoutCard4_Click">
                            <Grid Margin="6,6">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="3"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="3"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Row="0" Grid.Column="0" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="7" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="0" Grid.Column="2" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="7" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="0" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="7" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border Grid.Row="2" Grid.Column="2" Background="#E0E7FF" CornerRadius="2">
                                    <TextBlock Text="发票" FontSize="7" Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- 添加裁剪线 -->
                    <CheckBox x:Name="ChkCutLine" Content="✂ 添加裁剪线" FontSize="13" Margin="0,0,0,14"
                              Checked="CutLine_Changed" Unchecked="CutLine_Changed"/>

                    <Border Height="1" Background="#EBEBEB" Margin="0,0,0,14"/>

                    <!-- 边距设置 -->
                    <TextBlock Text="边距设置 (mm)" Style="{StaticResource LabelText}"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="6"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="6"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="上" Style="{StaticResource SubLabel}"/>
                            <TextBox x:Name="TxtMarginTop" Text="10" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="下" Style="{StaticResource SubLabel}"/>
                            <TextBox x:Name="TxtMarginBottom" Text="10" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0">
                            <TextBlock Text="左" Style="{StaticResource SubLabel}"/>
                            <TextBox x:Name="TxtMarginLeft" Text="10" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2">
                            <TextBlock Text="右" Style="{StaticResource SubLabel}"/>
                            <TextBox x:Name="TxtMarginRight" Text="10" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                        </StackPanel>
                    </Grid>

                    <!-- 套打偏移 -->
                    <StackPanel x:Name="PanelOffset" Margin="0,0,0,12" Visibility="Collapsed">
                        <TextBlock Text="套打偏移 (mm)" Style="{StaticResource LabelText}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="6"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="X" Style="{StaticResource SubLabel}"/>
                                <TextBox x:Name="TxtOffsetX" Text="0" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Y" Style="{StaticResource SubLabel}"/>
                                <TextBox x:Name="TxtOffsetY" Text="0" Padding="6,4" FontSize="12" Background="#F7F8FA" BorderBrush="#D1D5DB" TextChanged="MarginChanged"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- 打印质量 -->
                    <TextBlock Text="打印质量" Style="{StaticResource LabelText}"/>
                    <ComboBox x:Name="CmbQuality" Margin="0,0,0,16" SelectedIndex="1">
                        <ComboBoxItem Content="草稿 (150 DPI)"/>
                        <ComboBoxItem Content="标准 (300 DPI)"/>
                        <ComboBoxItem Content="高画质 (600 DPI)"/>
                    </ComboBox>

                    <Border Height="1" Background="#EBEBEB" Margin="0,0,0,14"/>

                    <!-- 操作按钮 -->
                    <Button Content="🖨️ 开始打印" Style="{StaticResource PrimaryBtn}" FontSize="14"
                            FontWeight="SemiBold" Padding="16,11" Click="BtnPrint_Click"/>
                    <Button Content="💾 保存为模板" Style="{StaticResource SecBtn}" Click="BtnSaveTemplate_Click"/>
                    <Button Content="🗑️ 删除模板" Style="{StaticResource SecBtn}" Click="BtnDeleteTemplate_Click"/>

                    <!-- 状态栏 -->
                    <Border Background="#F0F4FF" CornerRadius="6" Padding="10,8" Margin="0,14,0,0">
                        <TextBlock x:Name="TxtStatus" Text="就绪" FontSize="12" Foreground="#4E6EF2" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
