<Page x:Class="WpfApp1.Views.JsonToolPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5"
      Loaded="Page_Loaded">

    <Page.InputBindings>
        <KeyBinding Key="F" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Find}"/>
        <KeyBinding Key="Escape" Command="{x:Static ApplicationCommands.Stop}"/>
    </Page.InputBindings>

    <Page.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Find}" Executed="FindCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Stop}" Executed="EscCommand_Executed"/>
    </Page.CommandBindings>

    <Page.Resources>
        <Style x:Key="RBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 隐藏 TreeViewItem 默认箭头，自定义展开样式 -->
        <Style x:Key="GridTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- 嵌套表格的列头样式 -->
        <Style x:Key="ColHeader" TargetType="Border">
            <Setter Property="Background" Value="#0EA5E9"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,1,0"/>
        </Style>

        <!-- 表格单元格样式 -->
        <Style x:Key="CellBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>

        <!-- 行号单元格 -->
        <Style x:Key="RowNumBorder" TargetType="Border">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="MinWidth" Value="30"/>
        </Style>
    </Page.Resources>

    <Grid Margin="16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="🔧 JSON 处理工具" FontSize="20" FontWeight="Bold" Foreground="#1A2332"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="📂 导入" Padding="10,5" FontSize="12" Margin="0,0,4,0"
                        Background="#6366F1" Foreground="White" Style="{StaticResource RBtn}" Click="BtnImportJson_Click"/>
                <Button Content="💾 导出 JSON" Padding="10,5" FontSize="12" Margin="0,0,4,0"
                        Background="#10B981" Foreground="White" Style="{StaticResource RBtn}" Click="BtnExportJson_Click"/>
                <Button Content="📋 导出 CSV" Padding="10,5" FontSize="12"
                        Background="#F59E0B" Foreground="White" Style="{StaticResource RBtn}" Click="BtnExportCsv_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- 主内容：左 JSON 编辑器 + 右 GRID -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="2*" MinWidth="250"/>
                <ColumnDefinition x:Name="SplitterColumn" Width="8"/>
                <ColumnDefinition x:Name="RightPanelColumn" Width="3*" MinWidth="350"/>
            </Grid.ColumnDefinitions>

            <!-- ========== 左侧：JSON 编辑器 ========== -->
            <Border x:Name="JsonEditorPanel" Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,0,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.05" BlurRadius="6"/>
                </Border.Effect>
                <DockPanel>
                    <!-- 顶部工具栏 -->
                    <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="10,6" CornerRadius="8,8,0,0"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="JSON" FontSize="13" FontWeight="Bold" Foreground="#1A56DB"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="🔍" Padding="8,3" FontSize="11" Margin="0,0,3,0" ToolTip="查找 (Ctrl+F)"
                                        Background="#8B5CF6" Foreground="White" Style="{StaticResource RBtn}" Click="BtnToggleSearch_Click"/>
                                <Button Content="美化" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                        Background="#3B82F6" Foreground="White" Style="{StaticResource RBtn}" Click="BtnBeautify_Click"/>
                                <Button Content="压缩" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                        Background="#6B7280" Foreground="White" Style="{StaticResource RBtn}" Click="BtnMinify_Click"/>
                                <Button Content="校验" Padding="8,3" FontSize="11"
                                        Background="#10B981" Foreground="White" Style="{StaticResource RBtn}" Click="BtnValidate_Click"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- 搜索栏（默认隐藏，Ctrl+F 显示） -->
                    <Border x:Name="SearchPanel" DockPanel.Dock="Top" Background="#FEF3C7" Padding="8,5"
                            BorderBrush="#F59E0B" BorderThickness="0,0,0,1" Visibility="Collapsed">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtSearchCount" Text="" FontSize="11" Foreground="#92400E"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Button Content="▲" Padding="6,2" FontSize="10" Margin="0,0,2,0" ToolTip="上一个 (Shift+Enter)"
                                        Background="#F59E0B" Foreground="White" Style="{StaticResource RBtn}" Click="BtnSearchPrev_Click"/>
                                <Button Content="▼" Padding="6,2" FontSize="10" Margin="0,0,2,0" ToolTip="下一个 (Enter)"
                                        Background="#F59E0B" Foreground="White" Style="{StaticResource RBtn}" Click="BtnSearchNext_Click"/>
                                <Button Content="✕" Padding="6,2" FontSize="10" ToolTip="关闭 (Esc)"
                                        Background="#EF4444" Foreground="White" Style="{StaticResource RBtn}" Click="BtnCloseSearch_Click"/>
                            </StackPanel>
                             <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                             <TextBox x:Name="TxtSearchKeyword" FontSize="12" Padding="4,3" VerticalAlignment="Center"
                                      Background="White" BorderBrush="#D97706" BorderThickness="1" MinWidth="150"
                                      TextChanged="TxtSearchKeyword_TextChanged"
                                      KeyDown="TxtSearchKeyword_KeyDown"/>
                             <CheckBox x:Name="ChkSearchCaseSensitive"
                                       Content="Aa"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="#92400E"
                                       ToolTip="区分大小写"
                                       Checked="SearchOptionChanged"
                                       Unchecked="SearchOptionChanged"/>
                         </DockPanel>
                     </Border>

                    <!-- JSON 编辑器 -->
                    <RichTextBox x:Name="TxtJsonEditor"
                             AcceptsReturn="True" AcceptsTab="True"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontSize="13" FontFamily="Consolas, 'Courier New'"
                             Background="#1E293B" Foreground="#A5F3FC" CaretBrush="#F59E0B"
                             Padding="12,8" BorderThickness="0"
                             TextChanged="TxtJsonEditor_TextChanged">
                        <RichTextBox.Resources>
                            <Style TargetType="Paragraph">
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </RichTextBox.Resources>
                    </RichTextBox>
                </DockPanel>
            </Border>

            <!-- 分隔条 -->
            <GridSplitter x:Name="JsonToolSplitter" Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ========== 右侧：GRID 嵌套表格 ========== -->
            <Border x:Name="GridPanel" Grid.Column="2" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.05" BlurRadius="6"/>
                </Border.Effect>
                <DockPanel>
                    <!-- 顶部工具栏 -->
                    <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="10,6" CornerRadius="8,8,0,0"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="GRID" FontSize="13" FontWeight="Bold" Foreground="#1A56DB"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="TxtStatus" Text="就绪" FontSize="11" Foreground="#9CA3AF"
                                       VerticalAlignment="Center" Margin="12,0,0,0" DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="BtnToggleGridEdit" Content="✏️ 开启编辑" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                        Background="#F59E0B" Foreground="White" Style="{StaticResource RBtn}" Click="BtnToggleGridEdit_Click"/>
                                <Button x:Name="BtnToggleGridFullscreen" Content="⛶ 全屏" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                        Background="#2563EB" Foreground="White" Style="{StaticResource RBtn}" Click="BtnToggleGridFullscreen_Click"/>
                                <Button Content="🔍" Padding="8,3" FontSize="11" Margin="0,0,3,0" ToolTip="GRID 查找 (Ctrl+F)"
                                        Background="#8B5CF6" Foreground="White" Style="{StaticResource RBtn}" Click="BtnToggleGridSearch_Click"/>
                                <Button Content="📂 全部展开" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                        Background="#10B981" Foreground="White" Style="{StaticResource RBtn}" Click="BtnExpandAll_Click"/>
                                <Button Content="📁 全部折叠" Padding="8,3" FontSize="11"
                                        Background="#6B7280" Foreground="White" Style="{StaticResource RBtn}" Click="BtnCollapseAll_Click"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- GRID 搜索栏（默认隐藏） -->
                    <Border x:Name="GridSearchPanel" DockPanel.Dock="Top" Background="#EDE9FE" Padding="8,5"
                            BorderBrush="#8B5CF6" BorderThickness="0,0,0,1" Visibility="Collapsed">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                                <TextBlock x:Name="TxtGridSearchCount" Text="" FontSize="11" Foreground="#5B21B6"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <Button Content="▲" Padding="6,2" FontSize="10" Margin="0,0,2,0" ToolTip="上一个"
                                        Background="#8B5CF6" Foreground="White" Style="{StaticResource RBtn}" Click="BtnGridSearchPrev_Click"/>
                                <Button Content="▼" Padding="6,2" FontSize="10" Margin="0,0,2,0" ToolTip="下一个"
                                        Background="#8B5CF6" Foreground="White" Style="{StaticResource RBtn}" Click="BtnGridSearchNext_Click"/>
                                <Button Content="✕" Padding="6,2" FontSize="10" ToolTip="关闭 (Esc)"
                                        Background="#EF4444" Foreground="White" Style="{StaticResource RBtn}" Click="BtnCloseGridSearch_Click"/>
                            </StackPanel>
                            <TextBlock Text="🔍" FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="TxtGridSearchKeyword" FontSize="12" Padding="4,3" VerticalAlignment="Center"
                                     Background="White" BorderBrush="#7C3AED" BorderThickness="1" MinWidth="150"
                                     TextChanged="TxtGridSearchKeyword_TextChanged"
                                     KeyDown="TxtGridSearchKeyword_KeyDown"/>
                            <CheckBox x:Name="ChkGridSearchCaseSensitive"
                                      Content="Aa"
                                      Margin="8,0,0,0"
                                      VerticalAlignment="Center"
                                      Foreground="#5B21B6"
                                      ToolTip="区分大小写"
                                      Checked="GridSearchOptionChanged"
                                      Unchecked="GridSearchOptionChanged"/>
                        </DockPanel>
                    </Border>

                    <!-- 嵌套网格 TreeView -->
                    <ScrollViewer x:Name="GridScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                  Padding="10,6">
                        <StackPanel x:Name="GridContainer"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
