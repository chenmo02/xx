<Page x:Class="WpfApp1.Views.JsonToolPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5">

    <Page.Resources>
        <Style x:Key="RBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 隐藏 TreeViewItem 默认箭头，自定义展开样式 -->
        <Style x:Key="GridTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- 嵌套表格的列头样式 -->
        <Style x:Key="ColHeader" TargetType="Border">
            <Setter Property="Background" Value="#0EA5E9"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="0,0,1,0"/>
        </Style>

        <!-- 表格单元格样式 -->
        <Style x:Key="CellBorder" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinHeight" Value="30"/>
        </Style>

        <!-- 行号单元格 -->
        <Style x:Key="RowNumBorder" TargetType="Border">
            <Setter Property="Background" Value="#F1F5F9"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6,5"/>
            <Setter Property="MinWidth" Value="30"/>
        </Style>
    </Page.Resources>

    <Grid Margin="16,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="🔧 JSON 处理工具" FontSize="20" FontWeight="Bold" Foreground="#1A2332"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="📂 导入" Padding="10,5" FontSize="12" Margin="0,0,4,0"
                        Background="#6366F1" Foreground="White" Style="{StaticResource RBtn}" Click="BtnImportJson_Click"/>
                <Button Content="💾 导出 JSON" Padding="10,5" FontSize="12" Margin="0,0,4,0"
                        Background="#10B981" Foreground="White" Style="{StaticResource RBtn}" Click="BtnExportJson_Click"/>
                <Button Content="📋 导出 CSV" Padding="10,5" FontSize="12"
                        Background="#F59E0B" Foreground="White" Style="{StaticResource RBtn}" Click="BtnExportCsv_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- 主内容：左 JSON 编辑器 + 右 GRID -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" MinWidth="250"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="3*" MinWidth="350"/>
            </Grid.ColumnDefinitions>

            <!-- ========== 左侧：JSON 编辑器 ========== -->
            <Border Grid.Column="0" Background="White" CornerRadius="8" Margin="0,0,0,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.05" BlurRadius="6"/>
                </Border.Effect>
                <DockPanel>
                    <!-- 顶部工具栏 -->
                    <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="10,6" CornerRadius="8,8,0,0"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="JSON" FontSize="13" FontWeight="Bold" Foreground="#1A56DB"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="美化" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                        Background="#3B82F6" Foreground="White" Style="{StaticResource RBtn}" Click="BtnBeautify_Click"/>
                                <Button Content="压缩" Padding="8,3" FontSize="11" Margin="0,0,3,0"
                                        Background="#6B7280" Foreground="White" Style="{StaticResource RBtn}" Click="BtnMinify_Click"/>
                                <Button Content="校验" Padding="8,3" FontSize="11"
                                        Background="#10B981" Foreground="White" Style="{StaticResource RBtn}" Click="BtnValidate_Click"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- JSON 编辑器 -->
                    <TextBox x:Name="TxtJsonEditor"
                             AcceptsReturn="True" AcceptsTab="True" TextWrapping="NoWrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontSize="13" FontFamily="Consolas, 'Courier New'"
                             Background="#1E293B" Foreground="#A5F3FC" CaretBrush="#F59E0B"
                             Padding="12,8" BorderThickness="0"
                             TextChanged="TxtJsonEditor_TextChanged"/>
                </DockPanel>
            </Border>

            <!-- 分隔条 -->
            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch"
                          Background="Transparent" Cursor="SizeWE"/>

            <!-- ========== 右侧：GRID 嵌套表格 ========== -->
            <Border Grid.Column="2" Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.05" BlurRadius="6"/>
                </Border.Effect>
                <DockPanel>
                    <!-- 顶部工具栏 -->
                    <Border DockPanel.Dock="Top" Background="#F8FAFC" Padding="10,6" CornerRadius="8,8,0,0"
                            BorderBrush="#E5E7EB" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="GRID" FontSize="13" FontWeight="Bold" Foreground="#1A56DB"
                                       VerticalAlignment="Center" DockPanel.Dock="Left"/>
                            <TextBlock x:Name="TxtStatus" Text="就绪" FontSize="11" Foreground="#9CA3AF"
                                       VerticalAlignment="Center" Margin="12,0,0,0" DockPanel.Dock="Left"/>
                        </DockPanel>
                    </Border>

                    <!-- 嵌套网格 TreeView -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                                  Padding="10,6">
                        <StackPanel x:Name="GridContainer"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
