<Page x:Class="WpfApp1.Views.DrawBoardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
      Background="{DynamicResource PageBackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Border Grid.Row="0" Background="White" Padding="14,8" BorderBrush="#E5E5E5" BorderThickness="0,0,0,1">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🎨 Excalidraw 画板" FontSize="17" FontWeight="Bold" Foreground="#222"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStatus" Text="  加载中..." FontSize="12" Foreground="#999"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="📂 打开文件" Padding="12,6" FontSize="12" Margin="0,0,4,0"
                            Background="#6366F1" Foreground="White" Style="{DynamicResource ButtonSmall}"
                            Click="BtnOpenFile_Click" ToolTip="打开 .excalidraw 文件"/>
                    <Button Content="💾 保存文件" Padding="12,6" FontSize="12" Margin="0,0,4,0"
                            Background="#10B981" Foreground="White" Style="{DynamicResource ButtonSmall}"
                            Click="BtnSaveFile_Click" ToolTip="保存为 .excalidraw 文件"/>
                    <Button Content="🖼️ 导出 PNG" Padding="12,6" FontSize="12" Margin="0,0,4,0"
                            Background="#F59E0B" Foreground="White" Style="{DynamicResource ButtonSmall}"
                            Click="BtnExportPng_Click"/>
                    <Button Content="📐 导出 SVG" Padding="12,6" FontSize="12" Margin="0,0,4,0"
                            Background="#8B5CF6" Foreground="White" Style="{DynamicResource ButtonSmall}"
                            Click="BtnExportSvg_Click"/>
                    <Border Width="1" Background="#E5E5E5" Margin="6,4"/>
                    <Button Content="🔄 刷新" Padding="12,6" FontSize="12" Margin="4,0,4,0"
                            Background="#6B7280" Foreground="White" Style="{DynamicResource ButtonSmall}"
                            Click="BtnRefresh_Click"/>
                    <Button Content="🌐 浏览器打开" Padding="12,6" FontSize="12"
                            Background="#4E6EF2" Foreground="White" Style="{DynamicResource ButtonSmall}"
                            Click="BtnOpenInBrowser_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- WebView2 -->
        <wv2:WebView2 x:Name="ExcalidrawWebView" Grid.Row="1"/>

        <!-- 加载遮罩 -->
        <Border x:Name="LoadingOverlay" Grid.Row="1" Background="#F5F6F8" Visibility="Visible">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="🎨" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock x:Name="TxtLoadingMsg" Text="正在加载 Excalidraw 画板..."
                           FontSize="16" Foreground="#666" HorizontalAlignment="Center"/>
                <TextBlock Text="首次加载需要网络连接" FontSize="12" Foreground="#999"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
