<Page x:Class="WpfApp1.Views.DataValidationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="clr-namespace:WpfApp1.Views"
      Background="#F0F2F5"
      x:Name="PageRoot">

    <Page.Resources>
        <!-- ── 通用按钮 ─────────────────────────────────────── -->
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#4E6EF2"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.78"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#64748B"/>
        </Style>
        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
        </Style>
        <Style x:Key="GreenBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#059669"/>
        </Style>

        <Style x:Key="GridContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D8E1F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="HasDropShadow" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.14" Color="#0F172A"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GridContextMenuItem" TargetType="MenuItem">
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EEF2FF"/>
                                <Setter Property="Foreground" Value="#3152E0"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ItemBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ValidationOptionChip" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Border x:Name="ChipBorder"
                                Background="White"
                                BorderBrush="#DCE5F3"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="14,12"
                                Margin="0,0,12,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="Dot"
                                        Width="10"
                                        Height="10"
                                        CornerRadius="5"
                                        Background="#CBD5E1"
                                        VerticalAlignment="Center"/>

                                <ContentPresenter Grid.Column="1"
                                                  Margin="10,0,12,0"
                                                  VerticalAlignment="Center"/>

                                <Border x:Name="StateBadge"
                                        Grid.Column="2"
                                        Background="#F8FAFC"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="999"
                                        Padding="8,3"
                                        VerticalAlignment="Center">
                                    <TextBlock x:Name="StateText"
                                               Text="未启用"
                                               FontSize="11"
                                               Foreground="#94A3B8"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="#BFD0F6"/>
                                <Setter TargetName="ChipBorder" Property="Background" Value="#FAFCFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChipBorder" Property="BorderBrush" Value="#6D7CF6"/>
                                <Setter TargetName="ChipBorder" Property="Background" Value="#F3F6FF"/>
                                <Setter TargetName="Dot" Property="Background" Value="#5B6EF5"/>
                                <Setter TargetName="StateBadge" Property="Background" Value="#E7EDFF"/>
                                <Setter TargetName="StateBadge" Property="BorderBrush" Value="#C7D2FE"/>
                                <Setter TargetName="StateText" Property="TextBlock.Text" Value="已启用"/>
                                <Setter TargetName="StateText" Property="Foreground" Value="#3F56E8"/>
                                <Setter Property="Foreground" Value="#3749D8"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ChipBorder" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 卡片 ───────────────────────────────────────────── -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ── 输入框（圆角） ──────────────────────────────────── -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Padding="{TemplateBinding Padding}"
                                          VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                          HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4E6EF2"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4E6EF2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── 圆角下拉框 ──────────────────────────────────────── -->
        <Style x:Key="FlatComboBox" TargetType="ComboBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="#CBD5E1" BorderThickness="1" CornerRadius="8"
                                    Padding="10,6,28,6" SnapsToDevicePixels="True">
                                <ContentPresenter IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <!-- 箭头 -->
                            <Path x:Name="Arrow" Data="M0,0 L4,4 L8,0" Stroke="#94A3B8" StrokeThickness="1.5"
                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0"
                                  Fill="Transparent" IsHitTestVisible="False"/>
                            <ToggleButton Opacity="0" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press" Focusable="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" PopupAnimation="Slide" Focusable="False">
                                <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                                        CornerRadius="8" Margin="0,4,0,0" Padding="4"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.12" Color="#000"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#94A3B8"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4E6EF2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Padding" Value="10,7"/>
                    <Setter Property="FontSize" Value="13"/>
                    <Setter Property="Foreground" Value="#374151"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                        CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF2FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- ── DataGrid 内嵌下拉框（紧凑圆角） ──────────────────── -->
        <Style x:Key="InlineCb" TargetType="ComboBox">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent" BorderThickness="1" CornerRadius="6"
                                    Padding="6,3,22,3" SnapsToDevicePixels="True">
                                <ContentPresenter IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <Path Data="M0,0 L3.5,3.5 L7,0" Stroke="#94A3B8" StrokeThickness="1.2"
                                  HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,7,0"
                                  Fill="Transparent" IsHitTestVisible="False"/>
                            <ToggleButton Opacity="0" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press" Focusable="False"/>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                   AllowsTransparency="True" PopupAnimation="Slide" Focusable="False">
                                <Border Background="White" BorderBrush="#CBD5E1" BorderThickness="1"
                                        CornerRadius="6" Margin="0,2,0,0" Padding="3"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}" MinWidth="{TemplateBinding ActualWidth}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.10" Color="#000"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#CBD5E1"/>
                                <Setter TargetName="Bd" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4E6EF2"/>
                                <Setter TargetName="Bd" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Resources>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Padding" Value="8,5"/>
                    <Setter Property="FontSize" Value="12"/>
                    <Setter Property="Foreground" Value="#374151"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bg" Background="{TemplateBinding Background}"
                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#EEF2FF"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bg" Property="Background" Value="#DBEAFE"/>
                                        <Setter Property="Foreground" Value="#1D4ED8"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Style.Resources>
        </Style>

        <!-- ── DataGrid 列头 ──────────────────────────────────── -->
        <Style x:Key="DgHeader" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="Foreground" Value="#334155"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Padding" Value="10,9"/>
            <Setter Property="BorderBrush" Value="#EEF2F7"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="DgCell" TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#EEF2F7"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8EEFF"/>
                    <Setter Property="Foreground" Value="#111827"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- 映射表行样式（带必填高亮） -->
        <Style x:Key="DgRow" TargetType="DataGridRow">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFBFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8EEFF"/>
                </Trigger>
                <!-- 必填未映射行红色背景 -->
                <DataTrigger Binding="{Binding NeedsHighlight}" Value="True">
                    <Setter Property="Background" Value="#FEF2F2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 错误列表行样式 -->
        <Style x:Key="DgIssueRow" TargetType="DataGridRow">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="#FAFBFF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F1F5FF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#E8EEFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── 值转换器 ──────────────────────────────────────── -->
        <local:BoolVisConverter x:Key="BoolVis"/>
        <local:BoolYesNoConverter x:Key="BoolYesNo"/>
        <local:RequiredColorConverter x:Key="RequiredColor"/>
        <local:IssueColorConverter x:Key="IssueColor"/>

        <!-- ── 步骤圆圈 ─────────────────────────────────────── -->
        <Style x:Key="StepCircle" TargetType="Border">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Background" Value="#D1D5DB"/>
        </Style>
        <Style x:Key="StepCircleActive" TargetType="Border" BasedOn="{StaticResource StepCircle}">
            <Setter Property="Background" Value="#4E6EF2"/>
        </Style>
        <Style x:Key="StepCircleDone" TargetType="Border" BasedOn="{StaticResource StepCircle}">
            <Setter Property="Background" Value="#10B981"/>
        </Style>
    </Page.Resources>

    <DockPanel Margin="24,16,24,20">

        <!-- ══ 页头 ══════════════════════════════════════════════ -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="数据验证排查" FontSize="22" FontWeight="Bold" Foreground="#111827"/>
            <TextBlock Text="粘贴建表语句和插入语句，自动完成字段映射与入库前校验，生成错误报告。"
                       Margin="0,4,0,0" FontSize="13" Foreground="#64748B"/>
        </StackPanel>

        <!-- ══ 步骤指示器 ════════════════════════════════════════ -->
        <Border DockPanel.Dock="Top" Style="{StaticResource Card}" Padding="20,14" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                <!-- Step 1 -->
                <StackPanel HorizontalAlignment="Center" Width="80">
                    <Border x:Name="Step1Circle" Style="{StaticResource StepCircleActive}"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="Step1Num" Text="1" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step1Label" Text="结构输入" FontSize="11" TextAlignment="Center"
                               Foreground="#4E6EF2" FontWeight="SemiBold" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Width="60" Height="2" Background="#D1D5DB" VerticalAlignment="Center"
                        Margin="0,0,0,18" x:Name="Line12"/>

                <!-- Step 2 -->
                <StackPanel HorizontalAlignment="Center" Width="80">
                    <Border x:Name="Step2Circle" Style="{StaticResource StepCircle}"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="Step2Num" Text="2" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step2Label" Text="数据输入" FontSize="11" TextAlignment="Center"
                               Foreground="#9CA3AF" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Width="60" Height="2" Background="#D1D5DB" VerticalAlignment="Center"
                        Margin="0,0,0,18" x:Name="Line23"/>

                <!-- Step 3 -->
                <StackPanel HorizontalAlignment="Center" Width="80">
                    <Border x:Name="Step3Circle" Style="{StaticResource StepCircle}"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="Step3Num" Text="3" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step3Label" Text="字段映射" FontSize="11" TextAlignment="Center"
                               Foreground="#9CA3AF" Margin="0,4,0,0"/>
                </StackPanel>

                <Border Width="60" Height="2" Background="#D1D5DB" VerticalAlignment="Center"
                        Margin="0,0,0,18" x:Name="Line34"/>

                <!-- Step 4 -->
                <StackPanel HorizontalAlignment="Center" Width="80">
                    <Border x:Name="Step4Circle" Style="{StaticResource StepCircle}"
                            HorizontalAlignment="Center">
                        <TextBlock x:Name="Step4Num" Text="4" FontSize="13" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="Step4Label" Text="校验结果" FontSize="11" TextAlignment="Center"
                               Foreground="#9CA3AF" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ══ 导航按钮行（固定底部）══════════════════════════════ -->
        <Border DockPanel.Dock="Bottom" Padding="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtStatus" Grid.Column="0" FontSize="12"
                           Foreground="#64748B" VerticalAlignment="Center"/>
                <Button x:Name="BtnBack" Grid.Column="1" Content="← 上一步"
                        Style="{StaticResource GhostBtn}" Margin="0,0,8,0"
                        Visibility="Collapsed" Click="BtnBack_Click"/>
                <Button x:Name="BtnNext" Grid.Column="2" Content="下一步 →"
                        Style="{StaticResource PrimaryBtn}" Click="BtnNext_Click"/>
            </Grid>
        </Border>

        <!-- ══ 步骤内容区（填满剩余空间）══════════════════════════ -->
        <Border Style="{StaticResource Card}" Padding="24,20">
            <Grid x:Name="ContentArea">

                <!-- ─── Step 1：结构输入 ─────────────────────── -->
                <DockPanel x:Name="Panel1" Visibility="Visible">

                    <!-- DB类型 + 表名 -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="280"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="数据库类型" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#374151" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <RadioButton x:Name="RbSqlServer" Content="SQL Server" GroupName="DbType"
                                         FontSize="13" Margin="0,0,16,0" Foreground="#374151"
                                         Checked="DbType_Changed"/>
                            <RadioButton x:Name="RbPostgreSql" Content="PostgreSQL" GroupName="DbType"
                                         IsChecked="True" FontSize="13" Foreground="#374151"
                                         Checked="DbType_Changed"/>
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="目标表名" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#374151" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <TextBox x:Name="TxtTableName" Grid.Column="4" Style="{StaticResource InputBox}"/>
                    </Grid>

                    <Border DockPanel.Dock="Top" Height="1" Background="#E5E7EB" Margin="0,0,0,14"/>
                    <TextBlock DockPanel.Dock="Top" Text="结构输入方式" FontSize="13" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,10"/>

                    <!-- 两卡片区域，填满剩余高度 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- DDL 模式卡片 -->
                        <Border x:Name="DdlCard" Grid.Column="0" CornerRadius="10" Padding="2"
                                Background="#4E6EF2" BorderThickness="0">
                            <Border CornerRadius="8" Background="White" Padding="18,16">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                        <RadioButton x:Name="RbDdlMode" Content="DDL 建表语句（推荐）"
                                                     GroupName="StructMode" IsChecked="True"
                                                     FontSize="13" FontWeight="SemiBold" Foreground="#1E3A8A"
                                                     Checked="StructMode_Changed"/>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="直接粘贴 CREATE TABLE 语句，表名和字段会自动解析"
                                               FontSize="12" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TxtDdlStatus" Grid.Column="0"
                                                   FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="清空" Style="{StaticResource GhostBtn}"
                                                Padding="10,6" FontSize="12" Margin="0,0,8,0"
                                                Click="BtnClearDdl_Click"/>
                                        <Button Grid.Column="2" Content="解析 DDL"
                                                Style="{StaticResource PrimaryBtn}"
                                                Padding="14,7" FontSize="12"
                                                Click="BtnParseDdl_Click"/>
                                    </Grid>
                                    <Grid>
                                        <TextBox x:Name="TxtDdl" AcceptsReturn="True"
                                                 AcceptsTab="True" VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 Style="{StaticResource InputBox}"
                                                 TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12"/>
                                        <Border x:Name="DdlPasteOverlay" Visibility="Collapsed"
                                                Background="#E8EEFFCC" CornerRadius="4">
                                            <TextBlock Text="正在粘贴数据..." FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </Border>

                        <!-- SQL 查询导入卡片 -->
                        <Border x:Name="StructExcelCard" Grid.Column="2" CornerRadius="10" Padding="0"
                                Background="Transparent" BorderThickness="0">
                            <Border x:Name="StructExcelInner" CornerRadius="8" Background="White" Padding="18,16"
                                    BorderBrush="#E5E7EB" BorderThickness="1">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                        <RadioButton x:Name="RbExcelStructMode" Content="SQL 查询导入（备用）"
                                                     GroupName="StructMode" FontSize="13" FontWeight="SemiBold"
                                                     Foreground="#374151" Checked="StructMode_Changed"/>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="在数据库中执行以下查询，将结果导出为 Excel 后导入"
                                               FontSize="12" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="复制查询语句" Style="{StaticResource GhostBtn}"
                                                    Padding="10,5" FontSize="12" Margin="0,0,8,0"
                                                    Click="BtnCopyStructQuery_Click"/>
                                            <Button Content="导入结果 Excel" Style="{StaticResource SecondaryBtn}"
                                                    Padding="10,5" FontSize="12"
                                                    Click="BtnImportStructExcel_Click"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TxtStructExcelInfo" FontSize="12"
                                                   Foreground="#64748B" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBox x:Name="TxtStructQuery" IsReadOnly="True"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap" FontFamily="Consolas" FontSize="11"
                                             Background="#F8FAFC" BorderBrush="#D1D5DB" BorderThickness="1"
                                             VerticalScrollBarVisibility="Auto" Padding="8,6"/>
                                </DockPanel>
                            </Border>
                        </Border>
                    </Grid>
                </DockPanel>

                <!-- ─── Step 2：数据输入 ─────────────────────── -->
                <DockPanel x:Name="Panel2" Visibility="Collapsed">
                    <TextBlock DockPanel.Dock="Top" Text="数据输入方式" FontSize="13" FontWeight="SemiBold"
                               Foreground="#374151" Margin="0,0,0,10"/>

                    <!-- 两卡片区域，填满剩余高度 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- INSERT 模式 -->
                        <Border x:Name="InsertCard" Grid.Column="0" CornerRadius="10" Padding="2"
                                Background="#4E6EF2" BorderThickness="0">
                            <Border CornerRadius="8" Background="White" Padding="18,16">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                                        <RadioButton x:Name="RbInsertMode" Content="INSERT INTO 语句（推荐）"
                                                     GroupName="DataMode" IsChecked="True"
                                                     FontSize="13" FontWeight="SemiBold" Foreground="#1E3A8A"
                                                     Checked="DataMode_Changed"/>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Top" Text="直接粘贴 INSERT INTO 语句，支持单行/多行/多值组"
                                               FontSize="12" Foreground="#64748B" Margin="0,0,0,8"/>
                                    <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="TxtInsertStatus" Grid.Column="0"
                                                   FontSize="12" Foreground="#64748B" VerticalAlignment="Center"/>
                                        <Button Grid.Column="1" Content="清空" Style="{StaticResource GhostBtn}"
                                                Padding="10,6" FontSize="12" Margin="0,0,8,0"
                                                Click="BtnClearInsert_Click"/>
                                        <Button Grid.Column="2" Content="解析 INSERT"
                                                Style="{StaticResource PrimaryBtn}"
                                                Padding="14,7" FontSize="12"
                                                Click="BtnParseInsert_Click"/>
                                    </Grid>
                                    <Grid>
                                        <TextBox x:Name="TxtInsert" AcceptsReturn="True"
                                                 AcceptsTab="True" VerticalScrollBarVisibility="Auto"
                                                 HorizontalScrollBarVisibility="Auto"
                                                 Style="{StaticResource InputBox}"
                                                 TextWrapping="NoWrap" FontFamily="Consolas" FontSize="12"/>
                                        <Border x:Name="InsertPasteOverlay" Visibility="Collapsed"
                                                Background="#E8EEFFCC" CornerRadius="4">
                                            <TextBlock Text="正在粘贴数据..." FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#4E6EF2" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </Grid>
                                </DockPanel>
                            </Border>
                        </Border>

                        <!-- Excel 数据 -->
                        <Border x:Name="DataExcelCard" Grid.Column="2" CornerRadius="10" Padding="0"
                                Background="Transparent" BorderThickness="0">
                            <Border x:Name="DataExcelInner" CornerRadius="8" Background="White" Padding="18,16"
                                    BorderBrush="#E5E7EB" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <RadioButton x:Name="RbExcelDataMode" Content="Excel 数据文件（备用）"
                                                     GroupName="DataMode" FontSize="13" FontWeight="SemiBold"
                                                     Foreground="#374151" Checked="DataMode_Changed"/>
                                    </StackPanel>
                                    <TextBlock Text="导入中间表数据 Excel，第一行必须为表头"
                                               FontSize="12" Foreground="#64748B" Margin="0,0,0,24"/>
                                    <Button Content="导入数据 Excel" Style="{StaticResource SecondaryBtn}"
                                            Padding="16,9" FontSize="13" HorizontalAlignment="Left"
                                            Click="BtnImportDataExcel_Click"/>
                                    <TextBlock x:Name="TxtDataExcelInfo" FontSize="12"
                                               Foreground="#64748B" Margin="0,12,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Border>
                    </Grid>
                </DockPanel>

                <!-- ─── Step 3：字段映射 ─────────────────────── -->
                <DockPanel x:Name="Panel3" Visibility="Collapsed" LastChildFill="True">

                    <!-- 主键选择 -->
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="中间表主键" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#374151" VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <ComboBox x:Name="CbPk1" Width="170" Margin="0,0,8,0"
                                  Style="{StaticResource FlatComboBox}"/>
                        <ComboBox x:Name="CbPk2" Width="170" Margin="0,0,12,0"
                                  Style="{StaticResource FlatComboBox}"/>
                        <TextBlock Text="(选填，用于错误报告中按主键定位记录)" FontSize="11"
                                   Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 工具栏 -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock FontSize="14" FontWeight="SemiBold" Foreground="#1F2937">
                                <Run Text="字段映射配置"/>
                                <Run x:Name="RunMappingInfo" Text="" Foreground="#6B7280" FontWeight="Normal" FontSize="12"/>
                            </TextBlock>
                            <TextBlock x:Name="TxtMappingHint" FontSize="12" Foreground="#EF4444"
                                       Margin="0,2,0,0" Visibility="Collapsed"
                                       Text="存在必填目标字段未映射，请处理后再继续"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Button Content="忽略自动生成UUID" Style="{StaticResource GhostBtn}"
                                    Padding="12,7" FontSize="12" Margin="0,0,8,0"
                                    Click="BtnIgnoreAllUuid_Click"/>
                            <Button Content="重新自动映射" Style="{StaticResource GhostBtn}"
                                    Padding="12,7" FontSize="12" Margin="0,0,8,0"
                                    Click="BtnAutoMap_Click"/>
                            <Button x:Name="BtnNextUnconfirmed" Content="↓ 未确认" Style="{StaticResource GhostBtn}"
                                    Padding="12,7" FontSize="12" Margin="0,0,8,0"
                                    Click="BtnNextUnconfirmed_Click"/>
                            <Button Content="全部确认" Style="{StaticResource GreenBtn}"
                                    Padding="12,7" FontSize="12"
                                    Click="BtnConfirmAll_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- 字段映射 DataGrid -->
                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8" Padding="0">
                        <DataGrid x:Name="DgMapping"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserSortColumns="False"
                                  CanUserResizeRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#EEF2F7"
                                  BorderThickness="0"
                                  Background="White"
                                  AlternationCount="2"
                                  ColumnHeaderStyle="{StaticResource DgHeader}"
                                  CellStyle="{StaticResource DgCell}"
                                  RowStyle="{StaticResource DgRow}"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  VerticalScrollBarVisibility="Auto"
                                  FontSize="12"
                                  PreviewKeyDown="DataGrid_PreviewKeyDown"
                                  PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown">
                            <DataGrid.ContextMenu>
                                <ContextMenu Style="{StaticResource GridContextMenu}">
                                    <MenuItem Header="复制当前单元格"
                                              Style="{StaticResource GridContextMenuItem}"
                                              Click="CopyCurrentCellMenu_Click"/>
                                    <MenuItem Header="复制当前行"
                                              Style="{StaticResource GridContextMenuItem}"
                                              Click="CopyCurrentRowMenu_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>

                                <!-- 序号 -->
                                <DataGridTextColumn Header="#" Binding="{Binding RowIndex}"
                                                    Width="42" IsReadOnly="True"/>

                                <!-- 目标字段 -->
                                <DataGridTextColumn Header="目标字段" Binding="{Binding TargetColumnName}"
                                                    Width="120" IsReadOnly="True"/>

                                <!-- 类型 -->
                                <DataGridTextColumn Header="目标类型" Binding="{Binding TargetDisplayType}"
                                                    Width="110" IsReadOnly="True"/>

                                <!-- 必填 -->
                                <DataGridTemplateColumn Header="必填" Width="48" IsReadOnly="True">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding IsRequired, Converter={StaticResource BoolYesNo}}"
                                                       Foreground="{Binding IsRequired, Converter={StaticResource RequiredColor}}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 映射方式 -->
                                <DataGridTemplateColumn Header="映射方式" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox Style="{StaticResource InlineCb}"
                                                      SelectedItem="{Binding MappingTypeStr, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{Binding DataContext.MappingTypeOptions, RelativeSource={RelativeSource AncestorType=Page}}"
                                                      SelectionChanged="MappingType_Changed"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 来源/值（动态） -->
                                <DataGridTemplateColumn Header="来源字段 / 固定值" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <!-- Source: ComboBox -->
                                                <ComboBox Style="{StaticResource InlineCb}"
                                                          Visibility="{Binding IsSourceMode, Converter={StaticResource BoolVis}}"
                                                          SelectedItem="{Binding SourceColumnName, UpdateSourceTrigger=PropertyChanged}"
                                                          ItemsSource="{Binding DataContext.SourceHeaders, RelativeSource={RelativeSource AncestorType=Page}}"
                                                          SelectionChanged="SourceColumn_Changed"/>
                                                <!-- Constant: TextBox -->
                                                <TextBox Visibility="{Binding IsConstantMode, Converter={StaticResource BoolVis}}"
                                                         Text="{Binding ConstantValue, UpdateSourceTrigger=PropertyChanged}"
                                                         BorderThickness="0" Background="Transparent" FontSize="12" Padding="4,2"/>
                                            </Grid>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- 匹配方式 -->
                                <DataGridTextColumn Header="匹配方式" Binding="{Binding MatchMethodText}"
                                                    Width="80" IsReadOnly="True"/>

                                <!-- 命中原因 -->
                                <DataGridTextColumn Header="命中原因" Binding="{Binding MatchReasonText}"
                                                    Width="220" IsReadOnly="True"/>

                                <!-- 置信度 -->
                                <DataGridTextColumn Header="置信度" Binding="{Binding ConfidenceText}"
                                                    Width="60" IsReadOnly="True"/>

                                <!-- 已确认 -->
                                <DataGridTemplateColumn Header="已确认" Width="60">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsConfirmed, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>

                <!-- ─── Step 4：校验结果 ─────────────────────── -->
                <DockPanel x:Name="Panel4" Visibility="Collapsed" LastChildFill="True">

                    <!-- 操作区 -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0"
                                Background="White"
                                BorderBrush="#E4EAF3"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="18,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <DockPanel LastChildFill="True">
                                        <TextBlock Text="结果概览"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"/>
                                        <TextBlock Text="校验完成后可在此快速查看摘要并按需放宽规则。"
                                                   Margin="12,1,0,0"
                                                   FontSize="12"
                                                   Foreground="#94A3B8"/>
                                    </DockPanel>

                                    <Border x:Name="SummaryCard"
                                            Visibility="Collapsed"
                                            Background="#F8FBFF"
                                            BorderBrush="#E5ECF7"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="14,12"
                                            Margin="0,14,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,14,0">
                                                <TextBlock Text="总行数" FontSize="11.5" Foreground="#6B7280"/>
                                                <TextBlock x:Name="TxtTotalRows" Text="0" Margin="0,7,0,0"
                                                           FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="14,0,14,0">
                                                <TextBlock Text="异常记录" FontSize="11.5" Foreground="#6B7280"/>
                                                <TextBlock x:Name="TxtErrorCount" Text="0" Margin="0,7,0,0"
                                                           FontSize="20" FontWeight="Bold" Foreground="#DC2626"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="2" Margin="14,0,14,0">
                                                <TextBlock Text="错误项数" FontSize="11.5" Foreground="#6B7280"/>
                                                <TextBlock x:Name="TxtRawErrorCount" Text="0" Margin="0,7,0,0"
                                                           FontSize="20" FontWeight="Bold" Foreground="#2563EB"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="3" Margin="14,0,14,0">
                                                <TextBlock Text="警告记录" FontSize="11.5" Foreground="#6B7280"/>
                                                <TextBlock x:Name="TxtWarningCount" Text="0" Margin="0,7,0,0"
                                                           FontSize="20" FontWeight="Bold" Foreground="#D97706"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="4" Margin="14,0,0,0">
                                                <TextBlock Text="耗时" FontSize="11.5" Foreground="#6B7280"/>
                                                <TextBlock x:Name="TxtElapsed" Text="0.0s" Margin="0,7,0,0"
                                                           FontSize="20" FontWeight="Bold" Foreground="#1F2937"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Background="#FBFCFE"
                                            BorderBrush="#E7EDF5"
                                            BorderThickness="1"
                                            CornerRadius="12"
                                            Padding="16,14"
                                            Margin="0,12,0,0">
                                        <StackPanel>
                                            <DockPanel LastChildFill="True">
                                                <TextBlock Text="校验规则"
                                                           FontSize="13.5"
                                                           FontWeight="SemiBold"
                                                           Foreground="#1F2937"/>
                                                <TextBlock Text="仅影响格式校验，适合在明确了解数据来源时临时放宽。"
                                                           Margin="12,1,0,0"
                                                           FontSize="12"
                                                           Foreground="#94A3B8"/>
                                            </DockPanel>
                                            <UniformGrid Columns="3" Margin="0,12,0,0">
                                                <CheckBox x:Name="ChkSkipIntFormat"
                                                          Style="{StaticResource ValidationOptionChip}"
                                                          Content="忽略整数格式错误"
                                                          IsChecked="True"
                                                          ToolTip="存储过程会做类型转换时可勾选，跳过整数/长整数格式校验"/>
                                                <CheckBox x:Name="ChkSkipUuidFormat"
                                                          Style="{StaticResource ValidationOptionChip}"
                                                          Content="忽略 UUID 格式错误"
                                                          IsChecked="False"
                                                          ToolTip="勾选后将跳过 UUID / UNIQUEIDENTIFIER 字段的格式错误校验"/>
                                                <CheckBox x:Name="ChkSkipDateTimeFormat"
                                                          Style="{StaticResource ValidationOptionChip}"
                                                          Content="忽略日期时间格式错误"
                                                          IsChecked="False"
                                                          ToolTip="勾选后将跳过 datetime / timestamp 等字段的日期时间格式错误校验"/>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="1"
                                            Margin="18,32,0,0"
                                            VerticalAlignment="Top">
                                    <Button x:Name="BtnRunValidation"
                                            Content="▶ 开始校验"
                                            Style="{StaticResource PrimaryBtn}"
                                            Padding="20,11"
                                            MinWidth="148"
                                            Margin="0,0,0,10"
                                            Click="BtnRunValidation_Click"/>
                                    <Button x:Name="BtnExportReport"
                                            Content="导出 Excel 报告"
                                            Style="{StaticResource GreenBtn}"
                                            Padding="20,11"
                                            MinWidth="148"
                                            Visibility="Collapsed"
                                            Click="BtnExportReport_Click"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <Border x:Name="ProgressPanel"
                                Grid.Row="1"
                                Visibility="Collapsed"
                                Background="#EEF2FF"
                                BorderBrush="#DDE5FF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="16,12"
                                Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock x:Name="TxtProgress"
                                               Text="校验中..."
                                               FontSize="13"
                                               Foreground="#1E3A8A"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8"/>
                                    <ProgressBar x:Name="PbProgress"
                                                 Height="8"
                                                 Value="0"
                                                 Maximum="100"
                                                 Background="#CBD5E1"
                                                 Foreground="#4E6EF2"/>
                                </StackPanel>
                                <Button x:Name="BtnCancelValidation"
                                        Grid.Column="1"
                                        Content="取消"
                                        Style="{StaticResource GhostBtn}"
                                        Padding="14,6"
                                        FontSize="12"
                                        Margin="14,0,0,0"
                                        VerticalAlignment="Center"
                                        Click="BtnCancelValidation_Click"/>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 错误列表 DataGrid -->
                    <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="8">
                        <DataGrid x:Name="DgIssues"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserSortColumns="True"
                                  CanUserResizeRows="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#EEF2F7"
                                  BorderThickness="0"
                                  Background="White"
                                  AlternationCount="2"
                                  ColumnHeaderStyle="{StaticResource DgHeader}"
                                  CellStyle="{StaticResource DgCell}"
                                  RowStyle="{StaticResource DgIssueRow}"
                                  SelectionMode="Single"
                                  SelectionUnit="FullRow"
                                  VerticalScrollBarVisibility="Auto"
                                  FontSize="12"
                                  PreviewKeyDown="DataGrid_PreviewKeyDown"
                                  PreviewMouseRightButtonDown="DataGrid_PreviewMouseRightButtonDown">
                            <DataGrid.ContextMenu>
                                <ContextMenu Style="{StaticResource GridContextMenu}">
                                    <MenuItem Header="复制当前单元格"
                                              Style="{StaticResource GridContextMenuItem}"
                                              Click="CopyCurrentCellMenu_Click"/>
                                    <MenuItem Header="复制当前行"
                                              Style="{StaticResource GridContextMenuItem}"
                                              Click="CopyCurrentRowMenu_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding RowNumber}" Width="52"/>
                                <DataGridTextColumn Header="主键" Binding="{Binding PrimaryKeyDisplay}" Width="180"/>
                                <DataGridTextColumn Header="源字段" Binding="{Binding SourceColumnName}" Width="100"/>
                                <DataGridTextColumn Header="目标字段" Binding="{Binding TargetColumnName}" Width="120"/>
                                <DataGridTextColumn Header="目标类型" Binding="{Binding TargetDataType}" Width="100"/>
                                <DataGridTemplateColumn Header="级别" Width="60" SortMemberPath="Level">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding LevelText}"
                                                       Foreground="{Binding Level, Converter={StaticResource IssueColor}}"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="错误类型" Binding="{Binding ErrorType}" Width="160"/>
                                <DataGridTextColumn Header="实际值" Binding="{Binding ActualValue}" Width="140"/>
                                <DataGridTextColumn Header="说明" Binding="{Binding Message}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </DockPanel>

            </Grid>
        </Border>
    </DockPanel>
</Page>

