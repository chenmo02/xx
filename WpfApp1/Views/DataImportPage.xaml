<Page x:Class="WpfApp1.Views.DataImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5"
      AllowDrop="True"
      Focusable="True"
      Loaded="Page_Loaded"
      PreviewKeyDown="Page_PreviewKeyDown"
      DragEnter="Page_DragEnter"
      Drop="Page_Drop">

    <Page.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.88"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="36"/>
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="8"
                        Background="{TemplateBinding Background}"
                        BorderBrush="#D1D5DB" BorderThickness="1"/>
                <Border Grid.Column="0" CornerRadius="8,0,0,8" Background="Transparent"/>
                <Path x:Name="Arrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                      Data="M 0 0 L 5 5 L 10 0" Stroke="#888" StrokeThickness="1.5" Fill="Transparent"/>
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#4E6EF2"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="#4E6EF2"/>
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="Border" Property="BorderBrush" Value="#4E6EF2"/>
                    <Setter TargetName="Border" Property="Background" Value="#F8F9FF"/>
                    <Setter TargetName="Arrow" Property="Data" Value="M 0 5 L 5 0 L 10 5"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="#4E6EF2"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Background" Value="#F7F8FA"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="MinHeight" Value="36"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Template="{StaticResource ComboBoxToggleButton}"
                                          Background="{TemplateBinding Background}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"/>
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="12,0,36,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                            <Popup x:Name="Popup" Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Focusable="False"
                                   PopupAnimation="Slide">
                                <Grid x:Name="DropDown" SnapsToDevicePixels="True"
                                      MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder"
                                            Background="White" CornerRadius="8"
                                            BorderBrush="#E0E0E0" BorderThickness="1"
                                            Margin="0,2,0,0">
                                        <Border.Effect>
                                            <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.12" Color="#000"/>
                                        </Border.Effect>
                                    </Border>
                                    <ScrollViewer Margin="0,6,0,6" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="Transparent" Padding="{TemplateBinding Padding}"
                                Margin="4,1" CornerRadius="6">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#EDF0FF"/>
                                <Setter Property="Foreground" Value="#4E6EF2"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E0E7FF"/>
                                <Setter Property="Foreground" Value="#3B5BDB"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Background" Value="#F7F8FA"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="PreviewGridColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F3F3F3"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="BorderBrush" Value="#D9D9D9"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SeparatorBrush" Value="#D9D9D9"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewGridRowHeaderStyle" TargetType="DataGridRowHeader">
            <Setter Property="Background" Value="#F3F3F3"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="BorderBrush" Value="#D9D9D9"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRowHeader">
                        <Border x:Name="HeaderBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#EDEDED"/>
                            </Trigger>
                            <Trigger Property="IsRowSelected" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background" Value="#DDEBF7"/>
                                <Setter Property="Foreground" Value="#1F2937"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PreviewGridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="BorderBrush" Value="#E4E7EB"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border x:Name="CellBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="CellBorder" Property="Background" Value="#EAF2FF"/>
                                <Setter TargetName="CellBorder" Property="BorderBrush" Value="#5B9BD5"/>
                                <Setter Property="Foreground" Value="#111827"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <MultiTrigger>
                    <MultiTrigger.Conditions>
                        <Condition Property="IsSelected" Value="True"/>
                        <Condition Property="Selector.IsSelectionActive" Value="False"/>
                    </MultiTrigger.Conditions>
                    <Setter Property="Background" Value="#EEF4FB"/>
                    <Setter Property="BorderBrush" Value="#9DC3E6"/>
                    <Setter Property="Foreground" Value="#111827"/>
                </MultiTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PreviewGridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFA"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <ScrollViewer Style="{StaticResource PageScrollViewerStyle}"
                      Padding="28,24"
                      VerticalScrollBarVisibility="Visible"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      CanContentScroll="False"
                      IsDeferredScrollingEnabled="False">
            <StackPanel MaxWidth="1120">

            <TextBlock Text="数据导入 SQL 生成器"
                       FontSize="22"
                       FontWeight="Bold"
                       Foreground="#1A2332"
                       Margin="0,0,0,4"/>
            <TextBlock Text="支持 Excel / CSV / DBF，支持 PostgreSQL / SQL Server / MySQL / Oracle，支持编辑后重新生成。"
                       FontSize="14"
                       Foreground="#6B7A90"
                       Margin="0,0,0,20"/>

            <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.06" BlurRadius="10"/>
                </Border.Effect>
                <StackPanel>
                    <DockPanel Margin="0,0,0,14">
                        <TextBlock Text="1. 文件导入"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#2D3748"
                                   DockPanel.Dock="Left"/>
                        <TextBlock Text="支持拖拽文件到本页"
                                   FontSize="12"
                                   Foreground="#9CA3AF"
                                   HorizontalAlignment="Right"/>
                    </DockPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtFilePath"
                                 Grid.Column="0"
                                 IsReadOnly="True"
                                 Text="请选择 Excel / CSV / DBF 文件..."
                                 Foreground="#9CA3AF"/>
                        <Button x:Name="BtnSelectFile"
                                Grid.Column="1"
                                Content="浏览"
                                Padding="18,8"
                                Margin="10,0,0,0"
                                FontSize="13"
                                Background="#1A56DB"
                                Foreground="White"
                                Style="{StaticResource RoundedButton}"
                                Click="BtnSelectFile_Click"/>
                    </Grid>

                    <Border Background="#F8FAFC"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1"
                            CornerRadius="8"
                            Margin="0,12,0,0"
                            Padding="12,10">
                        <TextBlock Text="可导入 .xlsx / .xls / .csv / .dbf。CSV 自动识别编码和分隔符，DBF 可手动切换编码。"
                                   FontSize="12"
                                   Foreground="#64748B"/>
                    </Border>

                    <StackPanel x:Name="PanelSheetSelect" Visibility="Collapsed" Margin="0,12,0,0">
                        <TextBlock Text="选择 Sheet 工作表" FontSize="13" Foreground="#4A5568" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CbSheetList" SelectionChanged="CbSheetList_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel x:Name="PanelDbfEncoding" Visibility="Collapsed" Margin="0,12,0,0">
                        <TextBlock Text="DBF 编码" FontSize="13" Foreground="#4A5568" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CbDbfEncoding" SelectionChanged="CbDbfEncoding_SelectionChanged"/>
                    </StackPanel>

                    <TextBlock x:Name="TxtFileInfo" Text="" FontSize="12" Foreground="#6B7A90" Margin="0,10,0,0"/>
                    <TextBlock x:Name="TxtStatus" Text="就绪" FontSize="12" Foreground="#4B5563" Margin="0,4,0,0"/>
                    <ProgressBar x:Name="ProgressLoad" Height="10" Margin="0,10,0,0" Minimum="0" Maximum="100" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.06" BlurRadius="10"/>
                </Border.Effect>
                <StackPanel>
                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="2. 数据预览与编辑"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#2D3748"
                                   DockPanel.Dock="Left"/>
                        <TextBlock Text="双击单元格即可修改，生成 SQL 时使用当前表格内容"
                                   FontSize="12"
                                   Foreground="#9CA3AF"
                                   HorizontalAlignment="Right"/>
                    </DockPanel>

                    <Border Background="#F8FAFC"
                            BorderBrush="#D9D9D9"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="1">
                        <DataGrid x:Name="DgPreview"
                                  AutoGenerateColumns="True"
                                  IsReadOnly="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  CanUserReorderColumns="False"
                                  CanUserResizeRows="False"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  LoadingRow="DgPreview_LoadingRow"
                                  RowHeaderWidth="48"
                                  MaxHeight="380"
                                  Background="White"
                                  BorderThickness="0"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#E4E7EB"
                                  VerticalGridLinesBrush="#E4E7EB"
                                  FontSize="12"
                                  ColumnHeaderHeight="30"
                                  HeadersVisibility="All"
                                  RowBackground="White"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  SelectionUnit="CellOrRowHeader"
                                  SelectionMode="Extended"
                                  ColumnHeaderStyle="{StaticResource PreviewGridColumnHeaderStyle}"
                                  RowHeaderStyle="{StaticResource PreviewGridRowHeaderStyle}"
                                  CellStyle="{StaticResource PreviewGridCellStyle}"
                                  RowStyle="{StaticResource PreviewGridRowStyle}"/>
                    </Border>

                    <TextBlock x:Name="TxtPreviewInfo"
                               Text="请先选择数据文件"
                               FontSize="12"
                               Foreground="#9CA3AF"
                               Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.06" BlurRadius="10"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="3. SQL 生成配置"
                               FontSize="16"
                               FontWeight="SemiBold"
                               Foreground="#2D3748"
                               Margin="0,0,0,14"/>

                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="目标数据库类型" FontSize="13" Foreground="#4A5568" Margin="0,0,0,6"/>
                            <ComboBox x:Name="CbDatabaseType" SelectionChanged="DbType_Changed">
                                <ComboBoxItem Content="PostgreSQL" IsSelected="True"/>
                                <ComboBoxItem Content="SQL Server"/>
                                <ComboBoxItem Content="MySQL"/>
                                <ComboBoxItem Content="Oracle"/>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="表名" FontSize="13" Foreground="#4A5568" Margin="0,0,0,6"/>
                            <TextBox x:Name="TxtTableName" Text="TempTable"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="TxtTableHint"
                               Text="提示：PostgreSQL/MySQL 使用临时表语法，Oracle 使用全局临时表。"
                               FontSize="11"
                               Foreground="#9CA3AF"
                               Margin="0,0,0,10"/>

                    <WrapPanel Margin="0,0,0,10">
                        <CheckBox x:Name="ChkDropIfExists" Content="生成 DROP TABLE" IsChecked="True" Margin="0,0,20,0" FontSize="13"/>
                        <CheckBox x:Name="ChkBatchInsert" Content="批量 INSERT" IsChecked="True" Margin="0,0,20,0" FontSize="13"/>
                        <CheckBox x:Name="ChkLimitFieldLength" Content="限制文本字段长度(1000)" IsChecked="True" FontSize="13"/>
                    </WrapPanel>

                    <WrapPanel Margin="0,0,0,14">
                        <TextBlock Text="每批行数：" FontSize="13" Foreground="#4A5568" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtBatchSize" Width="70" Margin="8,0,0,0" Text="1000"/>
                        <TextBlock Text="  SQL Server 单批最大 1000，Oracle 批量时会转成 INSERT ALL。"
                                   FontSize="11"
                                   Foreground="#9CA3AF"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnGenerateSql"
                                Content="生成 SQL"
                                Padding="20,9"
                                FontSize="13"
                                FontWeight="SemiBold"
                                Background="#1A56DB"
                                Foreground="White"
                                Style="{StaticResource RoundedButton}"
                                Click="BtnGenerateSql_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="12" Padding="24,20">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.06" BlurRadius="10"/>
                </Border.Effect>
                <StackPanel>
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="4. SQL 与导出"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#2D3748"
                                   DockPanel.Dock="Left"
                                   VerticalAlignment="Center"/>
                        <WrapPanel HorizontalAlignment="Right">
                            <Button x:Name="BtnCopySql"
                                    Content="复制 SQL"
                                    Padding="14,6"
                                    FontSize="12"
                                    Background="#10B981"
                                    Foreground="White"
                                    Style="{StaticResource RoundedButton}"
                                    Margin="0,0,8,0"
                                    Click="BtnCopySql_Click"/>
                            <Button x:Name="BtnSaveSql"
                                    Content="保存 SQL"
                                    Padding="14,6"
                                    FontSize="12"
                                    Background="#6366F1"
                                    Foreground="White"
                                    Style="{StaticResource RoundedButton}"
                                    Margin="0,0,8,0"
                                    Click="BtnSaveSql_Click"/>
                            <Button x:Name="BtnExportCsv"
                                    Content="导出 CSV"
                                    Padding="14,6"
                                    FontSize="12"
                                    Background="#0F766E"
                                    Foreground="White"
                                    Style="{StaticResource RoundedButton}"
                                    Margin="0,0,8,0"
                                    Click="BtnExportCsv_Click"/>
                            <Button x:Name="BtnExportJson"
                                    Content="导出 JSON"
                                    Padding="14,6"
                                    FontSize="12"
                                    Background="#7C3AED"
                                    Foreground="White"
                                    Style="{StaticResource RoundedButton}"
                                    Click="BtnExportJson_Click"/>
                        </WrapPanel>
                    </DockPanel>

                    <TextBlock x:Name="TxtSqlStats" Text="" FontSize="12" Foreground="#6B7A90" Margin="0,0,0,8"/>

                    <TextBox x:Name="TxtSqlOutput"
                             Height="380"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             FontSize="12.5"
                             FontFamily="Consolas, Courier New"
                             Background="#1E293B"
                             Foreground="#A5F3FC"
                             Padding="14,12"
                             BorderThickness="0"
                             AcceptsReturn="True"/>
                </StackPanel>
            </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
