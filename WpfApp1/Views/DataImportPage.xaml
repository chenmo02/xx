<Page x:Class="WpfApp1.Views.DataImportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F0F2F5">

    <Page.Resources>
        <!-- 圆角按钮样式 -->
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="32,28">
        <StackPanel MaxWidth="920">

            <!-- 页面标题 -->
            <TextBlock Text="📊 数据导入 — SQL 生成器" FontSize="22" FontWeight="Bold" Foreground="#1A2332" Margin="0,0,0,4"/>
            <TextBlock Text="选择 Excel / CSV 文件，自动生成建临时表和插入数据的 SQL 语句" FontSize="14" Foreground="#6B7A90" Margin="0,0,0,24"/>

            <!-- ==================== Step 1: 选择文件 ==================== -->
            <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.06" BlurRadius="10"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="28" Height="28" CornerRadius="14" Background="#1A56DB" Margin="0,0,10,0">
                            <TextBlock Text="1" Foreground="White" FontWeight="Bold" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="选择数据文件" FontSize="16" FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TxtFilePath" Grid.Column="0"
                                 Padding="10,8" FontSize="13" IsReadOnly="True"
                                 Background="#F7F8FA" BorderBrush="#D1D5DB" BorderThickness="1"
                                 Text="请选择 Excel (.xlsx) 或 CSV (.csv) 文件..." Foreground="#9CA3AF"/>
                        <Button x:Name="BtnSelectFile" Grid.Column="1" Content="📁 浏览"
                                Padding="16,8" Margin="10,0,0,0" FontSize="13"
                                Background="#1A56DB" Foreground="White"
                                Style="{StaticResource RoundedButton}" Click="BtnSelectFile_Click"/>
                    </Grid>

                    <!-- Sheet 选择区域（Excel 时显示） -->
                    <StackPanel x:Name="PanelSheetSelect" Visibility="Collapsed" Margin="0,12,0,0">
                        <TextBlock Text="选择 Sheet 工作表" FontSize="13" Foreground="#4A5568" Margin="0,0,0,6"/>
                        <ComboBox x:Name="CbSheetList" FontSize="13" Padding="8,6"
                                  Background="#F7F8FA" BorderBrush="#D1D5DB"
                                  SelectionChanged="CbSheetList_SelectionChanged"/>
                    </StackPanel>

                    <!-- 文件信息 -->
                    <TextBlock x:Name="TxtFileInfo" Text="" FontSize="12" Foreground="#6B7A90" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ==================== Step 2: 数据预览 ==================== -->
            <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.06" BlurRadius="10"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="28" Height="28" CornerRadius="14" Background="#1A56DB" Margin="0,0,10,0">
                            <TextBlock Text="2" Foreground="White" FontWeight="Bold" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="数据预览" FontSize="16" FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                    </StackPanel>

                    <DataGrid x:Name="DgPreview" AutoGenerateColumns="True" IsReadOnly="True"
                              MaxHeight="260" Background="White" BorderThickness="1" BorderBrush="#E5E7EB"
                              GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#F3F4F6"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              FontSize="12" HeadersVisibility="Column">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F9FAFB"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Foreground" Value="#374151"/>
                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                    </DataGrid>
                    <TextBlock x:Name="TxtPreviewInfo" Text="请先选择数据文件"
                               FontSize="12" Foreground="#9CA3AF" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- ==================== Step 3: SQL 生成配置 ==================== -->
            <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.06" BlurRadius="10"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                        <Border Width="28" Height="28" CornerRadius="14" Background="#1A56DB" Margin="0,0,10,0">
                            <TextBlock Text="3" Foreground="White" FontWeight="Bold" FontSize="14"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="SQL 生成配置" FontSize="16" FontWeight="SemiBold" Foreground="#2D3748" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- 数据库类型 -->
                    <TextBlock Text="目标数据库类型" FontSize="13" Foreground="#4A5568" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                        <RadioButton x:Name="RbPostgres" Content="PostgreSQL" GroupName="DbType"
                                     IsChecked="True" Margin="0,0,24,0" FontSize="13"
                                     Checked="DbType_Changed"/>
                        <RadioButton x:Name="RbSqlServer" Content="SQL Server" GroupName="DbType"
                                     FontSize="13" Checked="DbType_Changed"/>
                    </StackPanel>

                    <!-- 临时表名 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="临时表名称" FontSize="13" Foreground="#4A5568" Margin="0,0,0,4"/>
                            <TextBox x:Name="TxtTableName" Padding="10,8" FontSize="13" Text="temp_import"
                                     Background="#F7F8FA" BorderBrush="#D1D5DB" BorderThickness="1"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                            <Button x:Name="BtnGenerateSql" Content="⚡ 生成 SQL"
                                    Padding="20,9" FontSize="13" FontWeight="SemiBold"
                                    Background="#1A56DB" Foreground="White"
                                    Style="{StaticResource RoundedButton}" Click="BtnGenerateSql_Click"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock x:Name="TxtTableHint" Text="提示：PostgreSQL 临时表建议使用 temp_ 前缀"
                               FontSize="11" Foreground="#9CA3AF" Margin="0,6,0,0"/>

                    <!-- 额外选项 -->
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <CheckBox x:Name="ChkDropIfExists" Content="生成 DROP TABLE IF EXISTS" IsChecked="True" Margin="0,0,20,0" FontSize="13"/>
                        <CheckBox x:Name="ChkBatchInsert" Content="批量 INSERT（多行 VALUES）" IsChecked="True" Margin="0,0,20,0" FontSize="13"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="每批行数：" FontSize="13" Foreground="#4A5568" VerticalAlignment="Center"/>
                        <TextBox x:Name="TxtBatchSize" Padding="8,4" FontSize="13" Text="100" Width="60"
                                 Background="#F7F8FA" BorderBrush="#D1D5DB" BorderThickness="1"/>
                        <TextBlock Text="  （SQL Server 单条 INSERT 最多 1000 行）" FontSize="11" Foreground="#9CA3AF" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ==================== Step 4: SQL 输出 ==================== -->
            <Border Background="White" CornerRadius="12" Padding="24,20" Margin="0,0,0,16">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="1" Opacity="0.06" BlurRadius="10"/>
                </Border.Effect>
                <StackPanel>
                    <!-- 标题栏 + 操作按钮 -->
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="📝 生成的 SQL 语句" FontSize="16" FontWeight="SemiBold" Foreground="#2D3748"
                                   VerticalAlignment="Center" DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button x:Name="BtnCopySql" Content="📋 复制到剪贴板"
                                    Padding="14,6" FontSize="12"
                                    Background="#10B981" Foreground="White"
                                    Style="{StaticResource RoundedButton}" Click="BtnCopySql_Click"
                                    Margin="0,0,8,0"/>
                            <Button x:Name="BtnSaveSql" Content="💾 保存为文件"
                                    Padding="14,6" FontSize="12"
                                    Background="#6366F1" Foreground="White"
                                    Style="{StaticResource RoundedButton}" Click="BtnSaveSql_Click"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- SQL 统计信息 -->
                    <TextBlock x:Name="TxtSqlStats" Text="" FontSize="12" Foreground="#6B7A90" Margin="0,0,0,8"/>

                    <!-- SQL 输出框 -->
                    <TextBox x:Name="TxtSqlOutput" Height="350" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             FontSize="12.5" FontFamily="Consolas, 'Courier New'"
                             Background="#1E293B" Foreground="#A5F3FC" Padding="14,12"
                             BorderThickness="0" AcceptsReturn="True"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
