<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="CC 实施工具箱" Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Icon="pack://application:,,,/favicon.ico"
        Background="#F5F6F8">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" Background="{DynamicResource NavBackgroundBrush}" BorderBrush="{DynamicResource NavBorderBrush}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border DockPanel.Dock="Top" Padding="18,20,18,16">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Border Width="36" Height="36" CornerRadius="8" Background="#4E6EF2" Margin="0,0,10,0">
                            <TextBlock Text="CC" FontSize="15" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="CC 工具箱" FontSize="16" FontWeight="Bold" Foreground="#222"/>
                            <TextBlock Text="实施小助手" FontSize="11" Foreground="#999" Margin="0,1,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border DockPanel.Dock="Top" Height="1" Background="#EBEBEB" Margin="14,0"/>

                <Border DockPanel.Dock="Bottom" Padding="14,10">
                    <TextBlock Text="v2.1.2  ©2026 CC Team" FontSize="10" Foreground="#BBB" HorizontalAlignment="Center"/>
                </Border>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                    <StackPanel>
                        <TextBlock Text="数据工具" FontSize="11" Foreground="#BBB" FontWeight="SemiBold" Margin="20,6,0,4"/>

                        <RadioButton x:Name="NavHome" Content="首页概览" Tag="🏠"
                                     Style="{StaticResource NavButtonStyle}" GroupName="Nav" IsChecked="True"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavImport" Content="数据导入临时表" Tag="📊"
                                     Style="{StaticResource NavButtonStyle}" GroupName="Nav"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavCsvViewer" Content="CSV 预览工具" Tag="📋"
                                     Style="{StaticResource NavButtonStyle}" GroupName="Nav"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavCsvCompare" Content="CSV 对比工具" Tag="🧮"
                                     Style="{StaticResource NavButtonStyle}" GroupName="Nav"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavDataValidation" Content="数据验证排查" Tag="✅"
                                     Style="{StaticResource NavButtonStyle}" GroupName="Nav"
                                     Checked="NavButton_Checked"/>

                        <Border Height="1" Background="#EBEBEB" Margin="14,8"/>

                        <TextBlock Text="开发工具" FontSize="11" Foreground="#BBB" FontWeight="SemiBold" Margin="20,6,0,4"/>

                        <RadioButton x:Name="NavJsonTool" Content="JSON 处理工具" Tag="📄"
                                     Style="{StaticResource NavButtonStyle}" GroupName="Nav"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavJsonDiff" Content="JSON 对比工具" Tag="🔀"
                                     Style="{StaticResource NavButtonStyle}" GroupName="Nav"
                                     Checked="NavButton_Checked"/>
                        <RadioButton x:Name="NavDrawBoard" Content="Excalidraw 画板" Tag="🎨"
                                     Style="{StaticResource NavButtonStyle}" GroupName="Nav"
                                     Checked="NavButton_Checked"/>

                        <Border Height="1" Background="#EBEBEB" Margin="14,8"/>

                        <TextBlock Text="办公工具" FontSize="11" Foreground="#BBB" FontWeight="SemiBold" Margin="20,6,0,4"/>

                        <RadioButton x:Name="NavInvoice" Content="发票打印工具" Tag="🖨️"
                                     Style="{StaticResource NavButtonStyle}" GroupName="Nav"
                                     Checked="NavButton_Checked"/>

                        <Border Height="1" Background="#EBEBEB" Margin="14,8"/>

                        <TextBlock Text="系统" FontSize="11" Foreground="#BBB" FontWeight="SemiBold" Margin="20,6,0,4"/>

                        <RadioButton x:Name="NavSettings" Content="系统设置" Tag="⚙️"
                                     Style="{StaticResource NavButtonStyle}" GroupName="Nav"
                                     Checked="NavButton_Checked"/>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- 右侧内容区 -->
        <Border Grid.Column="1">
            <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
        </Border>
    </Grid>
</Window>
