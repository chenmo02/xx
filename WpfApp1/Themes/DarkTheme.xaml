<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== 深色主题颜色定义（占位） ==================== -->
    <!-- 后续实现深色主题时，修改此文件中的颜色值即可 -->

    <!-- 品牌主色 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#6B8AFF"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#5470E6"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#2A2E45"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#33375A"/>

    <!-- 状态色 -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="#6EE7B7"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="ErrorLightBrush" Color="#FCA5A5"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24"/>
    <SolidColorBrush x:Key="WarningDarkBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="PurpleBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="PurpleLightBrush" Color="#C4B5FD"/>

    <!-- 页面背景 -->
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#1A1B2E"/>
    <SolidColorBrush x:Key="PageBackgroundAltBrush" Color="#1E1F36"/>

    <!-- 卡片/容器 -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#252742"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#3A3C5C"/>

    <!-- 输入控件 -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#2A2C4A"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#3A3C5C"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#6B8AFF"/>

    <!-- 分割线 -->
    <SolidColorBrush x:Key="DividerBrush" Color="#3A3C5C"/>

    <!-- 文字颜色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="TextDarkBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="#475569"/>

    <!-- DataGrid -->
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#2A2C4A"/>
    <SolidColorBrush x:Key="GridBorderBrush" Color="#3A3C5C"/>
    <SolidColorBrush x:Key="GridCellBorderBrush" Color="#333557"/>
    <SolidColorBrush x:Key="RowHoverBrush" Color="#2E3050"/>
    <SolidColorBrush x:Key="RowSelectedBrush" Color="#2A3555"/>
    <SolidColorBrush x:Key="RowSelectedBorderBrush" Color="#4A6FA5"/>
    <SolidColorBrush x:Key="RowSelectedInactiveBrush" Color="#282D48"/>
    <SolidColorBrush x:Key="RowSelectedInactiveBorderBrush" Color="#3A5580"/>
    <SolidColorBrush x:Key="RowHeaderHoverBrush" Color="#333557"/>
    <SolidColorBrush x:Key="RowHeaderSelectedBrush" Color="#2A3555"/>

    <!-- 按钮 -->
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#475569"/>
    <SolidColorBrush x:Key="ButtonGhostBackgroundBrush" Color="#333557"/>
    <SolidColorBrush x:Key="ButtonGhostForegroundBrush" Color="#CBD5E1"/>

    <!-- 侧边栏 -->
    <SolidColorBrush x:Key="NavBackgroundBrush" Color="#1E1F36"/>
    <SolidColorBrush x:Key="NavBorderBrush" Color="#3A3C5C"/>
    <SolidColorBrush x:Key="NavHoverBrush" Color="#2A2C4A"/>
    <SolidColorBrush x:Key="NavActiveBrush" Color="#2A2E45"/>
    <SolidColorBrush x:Key="NavTextBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="NavIconBrush" Color="#64748B"/>

    <!-- ComboBox 下拉 -->
    <SolidColorBrush x:Key="DropdownBackgroundBrush" Color="#252742"/>
    <SolidColorBrush x:Key="DropdownBorderBrush" Color="#3A3C5C"/>
    <SolidColorBrush x:Key="DropdownArrowBrush" Color="#94A3B8"/>

</ResourceDictionary>
