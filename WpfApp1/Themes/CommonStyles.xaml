<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:WpfApp1.Behaviors">

    <!-- 页面滚动条 -->
    <Style x:Key="PageScrollThumbStyle" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background" Value="{DynamicResource PageScrollThumbBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Width="6"
                            Margin="0,2"
                            HorizontalAlignment="Center"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background"
                                    Value="{DynamicResource PageScrollThumbHoverBrush}"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background"
                                    Value="{DynamicResource PageScrollThumbPressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <ControlTemplate x:Key="PageVerticalScrollBarTemplate" TargetType="ScrollBar">
        <Grid Width="{TemplateBinding Width}" Background="Transparent">
            <Border Width="6"
                    Margin="0,8"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource PageScrollTrackBrush}"
                    CornerRadius="3"/>
            <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageUpCommand"
                                  Focusable="False"
                                  IsTabStop="False"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Opacity="0"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource PageScrollThumbStyle}" MinHeight="40"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageDownCommand"
                                  Focusable="False"
                                  IsTabStop="False"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Opacity="0"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="PageHorizontalScrollBarTemplate" TargetType="ScrollBar">
        <Grid Height="{TemplateBinding Height}" Background="Transparent">
            <Border Height="6"
                    Margin="8,0"
                    VerticalAlignment="Center"
                    Background="{DynamicResource PageScrollTrackBrush}"
                    CornerRadius="3"/>
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageLeftCommand"
                                  Focusable="False"
                                  IsTabStop="False"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Opacity="0"/>
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource PageScrollThumbStyle}" MinWidth="40"/>
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Command="ScrollBar.PageRightCommand"
                                  Focusable="False"
                                  IsTabStop="False"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Opacity="0"/>
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <Style x:Key="PageScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Width" Value="14"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Template" Value="{StaticResource PageVerticalScrollBarTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Height" Value="14"/>
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Template" Value="{StaticResource PageHorizontalScrollBarTemplate}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- 页面 ScrollViewer -->
    <Style x:Key="PageScrollViewerStyle" TargetType="ScrollViewer">
        <Style.Resources>
            <Style TargetType="ScrollBar" BasedOn="{StaticResource PageScrollBarStyle}"/>
        </Style.Resources>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="CanContentScroll" Value="False"/>
        <Setter Property="PanningMode" Value="VerticalOnly"/>
        <Setter Property="behaviors:ScrollViewerAssist.EnableHiddenWheelScroll" Value="True"/>
    </Style>

    <!-- 侧边栏导航按钮 -->
    <Style x:Key="NavButtonStyle" TargetType="RadioButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border" Background="Transparent" CornerRadius="6"
                            Padding="14,10" Margin="6,2" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource NavIconBrush}"/>
                            <TextBlock x:Name="text" Text="{TemplateBinding Content}" FontSize="13.5"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource NavTextBrush}" FontWeight="Normal"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource NavHoverBrush}"/>
                            <Setter TargetName="text" Property="Foreground" Value="#222"/>
                            <Setter TargetName="icon" Property="Foreground" Value="#222"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource NavActiveBrush}"/>
                            <Setter TargetName="text" Property="Foreground"
                                    Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="text" Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="icon" Property="Foreground"
                                    Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
