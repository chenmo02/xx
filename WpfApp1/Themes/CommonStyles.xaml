<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:WpfApp1.Behaviors">

    <!-- ==================== 通用共享样式 ==================== -->

    <!-- 页面 ScrollViewer（隐藏滚动条、支持鼠标滚轮） -->
    <Style x:Key="PageScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Hidden"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="CanContentScroll" Value="False"/>
        <Setter Property="PanningMode" Value="VerticalOnly"/>
        <Setter Property="behaviors:ScrollViewerAssist.EnableHiddenWheelScroll" Value="True"/>
    </Style>

    <!-- 侧边栏导航按钮 -->
    <Style x:Key="NavButtonStyle" TargetType="RadioButton">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="border" Background="Transparent" CornerRadius="6"
                            Padding="14,10" Margin="6,2" Cursor="Hand">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0"
                                       Foreground="{DynamicResource NavIconBrush}"/>
                            <TextBlock x:Name="text" Text="{TemplateBinding Content}" FontSize="13.5"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource NavTextBrush}" FontWeight="Normal"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource NavHoverBrush}"/>
                            <Setter TargetName="text" Property="Foreground" Value="#222"/>
                            <Setter TargetName="icon" Property="Foreground" Value="#222"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="border" Property="Background"
                                    Value="{DynamicResource NavActiveBrush}"/>
                            <Setter TargetName="text" Property="Foreground"
                                    Value="{DynamicResource PrimaryBrush}"/>
                            <Setter TargetName="text" Property="FontWeight" Value="SemiBold"/>
                            <Setter TargetName="icon" Property="Foreground"
                                    Value="{DynamicResource PrimaryBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
