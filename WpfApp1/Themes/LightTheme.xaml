<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ==================== 浅色主题颜色定义 ==================== -->
    <!-- 切换主题时，只需替换此文件为 DarkTheme.xaml 即可 -->

    <!-- 品牌主色 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#4E6EF2"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#3B5BDB"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#EDF0FF"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#E0E7FF"/>

    <!-- 状态色 -->
    <SolidColorBrush x:Key="SuccessBrush" Color="#059669"/>
    <SolidColorBrush x:Key="SuccessLightBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="ErrorLightBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="WarningDarkBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="PurpleBrush" Color="#7C3AED"/>
    <SolidColorBrush x:Key="PurpleLightBrush" Color="#8B5CF6"/>

    <!-- 页面背景 -->
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F5F6F8"/>
    <SolidColorBrush x:Key="PageBackgroundAltBrush" Color="#F0F2F5"/>

    <!-- 卡片/容器 -->
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="#E5E7EB"/>

    <!-- 输入控件 -->
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="InputHoverBorderBrush" Color="#A8B4C5"/>
    <SolidColorBrush x:Key="InputFocusBorderBrush" Color="#4E6EF2"/>
    <SolidColorBrush x:Key="InputFocusBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="InputDisabledBackgroundBrush" Color="#F1F5F9"/>

    <!-- 分割线 -->
    <SolidColorBrush x:Key="DividerBrush" Color="#EBEBEB"/>

    <!-- 文字颜色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="TextDarkBrush" Color="#111827"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="TextLightBrush" Color="#BBB"/>

    <!-- DataGrid -->
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#F3F3F3"/>
    <SolidColorBrush x:Key="GridBorderBrush" Color="#D9D9D9"/>
    <SolidColorBrush x:Key="GridCellBorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="RowHoverBrush" Color="#FAFAFA"/>
    <SolidColorBrush x:Key="RowSelectedBrush" Color="#EAF2FF"/>
    <SolidColorBrush x:Key="RowSelectedBorderBrush" Color="#5B9BD5"/>
    <SolidColorBrush x:Key="RowSelectedInactiveBrush" Color="#EEF4FB"/>
    <SolidColorBrush x:Key="RowSelectedInactiveBorderBrush" Color="#9DC3E6"/>
    <SolidColorBrush x:Key="RowHeaderHoverBrush" Color="#EDEDED"/>
    <SolidColorBrush x:Key="RowHeaderSelectedBrush" Color="#E3EEF9"/>

    <!-- 按钮 -->
    <SolidColorBrush x:Key="ButtonSecondaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="ButtonGhostBackgroundBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="ButtonGhostForegroundBrush" Color="#475569"/>

    <!-- 侧边栏 -->
    <SolidColorBrush x:Key="NavBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NavBorderBrush" Color="#E5E5E5"/>
    <SolidColorBrush x:Key="NavHoverBrush" Color="#F0F1F5"/>
    <SolidColorBrush x:Key="NavActiveBrush" Color="#EDF0FF"/>
    <SolidColorBrush x:Key="NavTextBrush" Color="#666"/>
    <SolidColorBrush x:Key="NavIconBrush" Color="#999"/>

    <!-- ComboBox 下拉 -->
    <SolidColorBrush x:Key="DropdownBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="DropdownBorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="DropdownArrowBrush" Color="#888"/>
    <SolidColorBrush x:Key="DropdownScrollTrackBrush" Color="#EEF2F7"/>
    <SolidColorBrush x:Key="DropdownScrollThumbBrush" Color="#C3CBD8"/>
    <SolidColorBrush x:Key="DropdownScrollThumbHoverBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="DropdownScrollThumbPressedBrush" Color="#64748B"/>

    <!-- 页面滚动条 -->
    <SolidColorBrush x:Key="PageScrollTrackBrush" Color="#E8EDF4"/>
    <SolidColorBrush x:Key="PageScrollThumbBrush" Color="#C4CEDB"/>
    <SolidColorBrush x:Key="PageScrollThumbHoverBrush" Color="#9BAAC0"/>
    <SolidColorBrush x:Key="PageScrollThumbPressedBrush" Color="#71839D"/>

</ResourceDictionary>
